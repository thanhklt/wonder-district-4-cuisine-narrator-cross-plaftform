@{
    Layout = "_Layout";
    ViewData["Title"] = "Tổng quan";
}

<!-- ════════════════════════════════════
                         SCREEN 1: DASHBOARD OVERVIEW
                         ════════════════════════════════════ -->
<div id="view-dashboard" class="view-section active">

    <!-- Stats Row -->
    <div class="grid-4 mb-6">
        <div class="glass-card stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-tent"></i></div>
            <div>
                <p class="stat-label">Tổng số hội chợ</p>
                <p class="stat-value" id="stat-fairs">0</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon blue"><i class="fa-solid fa-store"></i></div>
            <div>
                <p class="stat-label">Số lượng gian hàng đang hoạt động</p>
                <p class="stat-value" id="stat-booths">0</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon amber"><i class="fa-solid fa-dollar-sign"></i></div>
            <div>
                <p class="stat-label">Tổng doanh thu</p>
                <p class="stat-value" id="stat-revenue">0 ₫</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon purple"><i class="fa-solid fa-users"></i></div>
            <div>
                <p class="stat-label">Tổng khách hàng</p>
                <p class="stat-value" id="stat-visitors">0</p>
            </div>
        </div>
    </div>

    <!-- Revenue Chart + Activity -->
    <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px; margin-bottom:24px;">
        <div class="glass-card" style="padding:24px;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-chart-line text-accent" style="margin-right:8px;"></i>Thống kê
                doanh thu
            </h3>
            <div class="chart-wrapper">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <div class="glass-card" style="padding:24px;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-bolt text-accent" style="margin-right:8px;"></i>Hoạt động gần
                đây
            </h3>
            <div id="activity-list">
                <!-- Injected by JS -->
            </div>
        </div>
    </div>

    <!-- Priority Leaderboard -->
    <div class="glass-card" style="padding:24px;">
        <div class="flex-between mb-4">
            <h3 style="font-size:16px; font-weight:700;">
                <i class="fa-solid fa-trophy text-accent" style="margin-right:8px;"></i>Bảng xếp
                hạng độ ưu tiên của gian hàng
            </h3>

        </div>
        <table class="leaderboard-table" id="leaderboard-table">
            <thead>
                <tr>
                    <th style="width:60px;">Số thứ tự</th>
                    <th>Tên gian hàng</th>
                    <th>Công ty</th>
                    <th>Hạng</th>
                    <th>Đơn hàng</th>
                    <th style="text-align:right;">Điểm ưu tiên</th>
                </tr>
            </thead>
            <tbody id="leaderboard-body">
                <!-- Injected by JS -->
            </tbody>
        </table>
    </div>
</div>

<!-- ════════════════════════════════════
                         SCREEN 2: BOOTH MANAGER
                         ════════════════════════════════════ -->
<div id="view-booths" class="view-section">

    <!-- Top Bar -->
    <div class="flex-between mb-4">
        <div>
            <h3 class="section-title">Quản lý gian hàng</h3>
            <p class="section-subtitle">Quản lý gian hàng, thuyết minh âm thanh và bán kính</p>
        </div>
        <div style="display:flex; gap:10px;">
            <button id="btn-add-booth" class="btn-primary btn-ripple">
                <i class="fa-solid fa-plus"></i> Thêm gian hàng
            </button>
            <button id="btn-save-booth" class="btn-primary btn-ripple">
                <i class="fa-solid fa-floppy-disk"></i> Lưu gian hàng
            </button>
        </div>
    </div>

    <!-- Split View -->
    <div class="booth-split">

        <!-- LEFT: Booth List -->
        <div class="glass-card booth-panel" style="padding-bottom:8px; align-self: start;">
            <div class="booth-panel-title" style="margin-bottom: 12px;">
                <i class="fa-solid fa-list"></i> Danh sách gian hàng
            </div>
            <div class="booth-list" id="booth-list">
                <!-- Injected by JS -->
            </div>
        </div>

        <!-- CENTER: Booth Form + Audio + Script -->
        <div style="display:flex; flex-direction:column; gap:20px;">

            <!-- Booth Details Form -->
            <div class="glass-card booth-panel">
                <div class="booth-panel-title">
                    <i class="fa-solid fa-pen-ruler"></i> Chi tiết gian hàng
                </div>

                <div class="grid-2 mb-4">
                    <div>
                        <label class="form-label">Tên gian hàng</label>
                        <input type="text" id="booth-name" class="form-input"
                               placeholder="Nhập tên gian hàng">
                    </div>
                    <div>
                        <label class="form-label">Công ty</label>
                        <input type="text" id="booth-company" class="form-input"
                               placeholder="Tên công ty">
                    </div>
                </div>

                <div class="grid-2 mb-4">
                    <div>
                        <label class="form-label">Danh mục</label>
                        <select id="booth-category" class="form-input form-select">
                            <option value="Technology">Công nghệ</option>
                            <option value="Food & Beverage">Thực phẩm & Đồ uống</option>
                            <option value="Fashion">Thời trang</option>
                            <option value="Health & Wellness">Sức khỏe & Thể chất</option>
                            <option value="Education">Giáo dục</option>
                            <option value="Art & Culture">Nghệ thuật & Văn hóa</option>
                            <option value="Automotive">Ô tô</option>
                            <option value="Other">Khác</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Gói dịch vụ</label>
                        <select id="booth-tier" class="form-input form-select">
                            <option value="Basic">Đơn giản</option>
                            <option value="Gold">Vàng</option>
                            <option value="Diamond">Kim cương</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Audio Editor -->
            <div class="glass-card booth-panel">
                <div class="flex-between mb-4">
                    <div class="booth-panel-title" style="margin-bottom:0;">
                        <i class="fa-solid fa-headphones-simple"></i> Thuyết minh sản phẩm
                    </div>
                    <span id="audio-status"
                          style="font-size:11px; color:var(--text-dim); background:rgba(255,255,255,0.04); padding:4px 10px; border-radius:6px;">
                        Không có file
                    </span>
                </div>

                <div class="audio-zone">
                    <!-- Upload Overlay -->
                    <div id="audio-upload-overlay" class="audio-upload-overlay">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <p style="font-size:13px; font-weight:500; color:var(--text-muted);">Nhấn hoặc kéo thả file âm thanh vào đây</p>
                        <p style="font-size:11px; color:var(--text-dim); margin-top:4px;">
                            MP3, WAV,
                            OGG (Tối đa 15MB)
                        </p>
                        <input type="file" id="audio-input" accept="audio/*" class="hidden">
                    </div>

                    <!-- Waveform -->
                    <div id="waveform" style="width:100%; height:80px; margin-bottom:12px;"></div>

                    <!-- Controls -->
                    <div class="audio-controls">
                        <div class="audio-playback">
                            <button id="btn-play" class="btn-play-circle" disabled>
                                <i class="fa-solid fa-play"></i>
                            </button>
                            <button id="btn-stop" class="btn-icon" disabled
                                    style="border-radius:50%; width:36px; height:36px;">
                                <i class="fa-solid fa-stop"></i>
                            </button>
                            <div class="volume-group">
                                <i class="fa-solid fa-volume-low"></i>
                                <input type="range" id="volume-slider" min="0" max="1" step="0.01"
                                       value="1">
                            </div>
                        </div>
                        <div class="time-display">
                            <span id="time-current">0:00</span> / <span id="time-total">0:00</span>
                        </div>
                    </div>
                </div>

                <button id="btn-clear-audio" class="btn-danger-ghost hidden mt-2">
                    <i class="fa-solid fa-trash-can"></i> Xóa file
                </button>
            </div>

            <!-- Script Editor -->
            <div class="glass-card booth-panel" style="position:relative; overflow:hidden;">
                <div style="position:absolute; top:-30px; right:-30px; width:100px; height:100px; background:radial-gradient(circle, rgba(34,197,94,0.08) 0%, transparent 70%); pointer-events:none; border-radius:50%;">
                </div>

                <div class="flex-between mb-4" style="position:relative; z-index:2;">
                    <div class="booth-panel-title" style="margin-bottom:0;">
                        <i class="fa-solid fa-pen-nib"></i>
                        <span id="script-title">Lời thoại (EN)</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <select id="lang-select" class="form-input form-select"
                                style="width:auto; padding:6px 32px 6px 10px; font-size:12px;">
                            <option value="VI">Tiếng Việt (VI)</option>
                            <option value="EN" selected>Tiếng Anh (EN)</option>
                            <option value="JA">Tiếng Nhật (JA)</option>
                            <option value="FR">Tiếng Pháp (FR)</option>
                            <option value="KO">Tiếng Hàn (KO)</option>
                            <option value="ZH">Tiếng Trung (ZH)</option>
                        </select>
                        <button id="btn-ai-optimize" class="btn-ai pulse-glow">
                            <i class="fa-solid fa-wand-magic-sparkles ai-icon"></i>
                            <span class="ai-text">Tối ưu bằng AI</span>
                        </button>
                    </div>
                </div>

                <div style="position:relative;">
                    <!-- AI Loading Overlay -->
                    <div id="ai-loading-overlay" class="ai-loading-overlay hidden">
                        <div class="ai-dots">
                            <span></span><span></span><span></span>
                        </div>
                        <p style="font-size:13px; font-weight:600; background:linear-gradient(90deg, var(--emerald), var(--forest-400)); background-clip:text; -webkit-background-clip:text; -webkit-text-fill-color:transparent;">
                            Emergent AI đang tối ưu
                        </p>
                    </div>
                </dive>



                        
                    <textarea id="booth-script" class="form-input" rows="8"
                              style="min-height:160px;"
                              placeholder="Viết kịch bản thuyết minh sản phẩm cho gian hàng này..."></textarea>
                </div>

                <div class="flex-between mt-2" style="position:relative; z-index:2;">
                    <span id="word-count" style="font-size:11px; color:var(--text-dim);">
                        0
                        từ
                    </span>
                    <span id="last-saved-time" style="font-size:11px; color:var(--text-dim);">
                        Chưa
                        được lưu
                    </span>
                </div>
            </div>
        </div>

        <!-- RIGHT: Map & Geofencing -->
        <div class="glass-card booth-panel" style="position:relative;">
            <div class="booth-panel-title">
                <i class="fa-solid fa-satellite-dish"></i> Phạm vi
            </div>

            <!-- Map Container -->
            <div id="map"
                 style="width:100%; height:220px; margin-bottom:20px; background:var(--bg-deep); border-radius:10px;">
            </div>

            <!-- Lat/Lng -->
            <div class="grid-2 mb-4">
                <div>
                    <label class="form-label">Vĩ độ</label>
                    <input type="number" step="0.000001" id="input-lat" value="10.7680"
                           class="form-input mono">
                </div>
                <div>
                    <label class="form-label">Kinh độ</label>
                    <input type="number" step="0.000001" id="input-lng" value="106.7050"
                           class="form-input mono">
                </div>
            </div>

            <!-- Radius Slider -->
            <div style="background:rgba(0,0,0,0.15); border-radius:10px; padding:14px; border:1px solid var(--border);">
                <div class="flex-between mb-2">
                    <label class="form-label" style="margin-bottom:0;">
                        <i class="fa-solid fa-bullseye text-accent"
                           style="margin-right:6px;"></i>Điều chỉnh bán kính
                    </label>
                    <span id="radius-val"
                          style="font-size:13px; font-weight:700; color:var(--emerald); background:rgba(34,197,94,0.1); padding:2px 10px; border-radius:6px;">30m</span>
                </div>
                <input type="range" id="radius-slider" min="10" max="50" value="30">
                <div class="flex-between mt-2"
                     style="font-size:10px; color:var(--text-dim); font-family:monospace;">
                    <span>10m</span>
                    <span>50m</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════
                         SCREEN 3: FINANCE & COMMISSION
                         ════════════════════════════════════ -->
<div id="view-finance" class="view-section">
    <div class="section-header">
        <div>
            <h3 class="section-title">Tài chính và hoa hồng</h3>
            <p class="section-subtitle">
                Theo dõi đơn hàng và tính toán hoa hồng cho mỗi gian hàng.
            </p>
        </div>
        <div class="booth-search-wrapper">
            <div class="booth-search-box">
                <i class="fa-solid fa-magnifying-glass booth-search-icon"></i>
                <input type="text" id="finance-booth-search" class="booth-search-input"
                       placeholder="Tìm kiếm gian hàng theo tên..." autocomplete="off">
                <button type="button" id="finance-search-clear" class="booth-search-clear hidden">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div id="finance-search-results" class="booth-search-results hidden">
                <!-- Populated by JS -->
            </div>
        </div>
    </div>

    <div class="finance-grid">
        <!-- Orders Table -->
        <div class="glass-card" style="padding:24px; overflow-x:auto;">
            <div class="flex-between mb-4">
                <h3 style="font-size:16px; font-weight:700;">
                    <i class="fa-solid fa-receipt text-accent" style="margin-right:8px;"></i>Đơn
                    hàng thành công
                </h3>
                <span id="order-count" style="font-size:12px; color:var(--text-muted);">
                    0
                    đơn
                </span>
            </div>
            <table class="orders-table" id="orders-table">
                <thead>
                    <tr>
                        <th>Mã đơn hàng</th>
                        <th>Sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Giá</th>
                        <th>Tổng</th>
                        <th>Trạng thái</th>
                        <th>Ngày</th>
                    </tr>
                </thead>
                <tbody id="orders-body">
                    <!-- Injected by JS -->
                </tbody>
            </table>
        </div>

        <!-- Commission Calculator -->
        <div class="glass-card commission-calc">
            <div class="booth-panel-title">
                <i class="fa-solid fa-calculator"></i> Tính toán hoa hồng
            </div>

            <div class="calc-formula">
                C = Σ(Price<sub>i</sub> × R<sub>c</sub>) + (n × F)
            </div>

            <div id="calc-details">
                <div class="calc-row">
                    <span class="calc-row-label">Hạng gian hàng</span>
                    <span class="calc-row-value" id="calc-tier">—</span>
                </div>
                <div class="calc-row">
                    <span class="calc-row-label">Tỷ lệ hoa hồng (R<sub>c</sub>)</span>
                    <span class="calc-row-value" id="calc-rc">—</span>
                </div>
                <div class="calc-row">
                    <span class="calc-row-label">Phí giao dịch (F)</span>
                    <span class="calc-row-value" id="calc-fee">—</span>
                </div>
                <div class="calc-row">
                    <span class="calc-row-label">Số lượng đơn hàng (n)</span>
                    <span class="calc-row-value" id="calc-n">—</span>
                </div>
                <div class="calc-row">
                    <span class="calc-row-label">Σ(Price<sub>i</sub> × R<sub>c</sub>)</span>
                    <span class="calc-row-value" id="calc-sum">—</span>
                </div>
                <div class="calc-row">
                    <span class="calc-row-label">n × F</span>
                    <span class="calc-row-value" id="calc-nf">—</span>
                </div>
            </div>

            <div class="calc-total">
                <p class="calc-total-label">Tổng hoa hồng (C)</p>
                <p class="calc-total-value" id="calc-total">0 ₫</p>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════
                         5. SUBSCRIPTION PLANS
                         ════════════════════════════════════ -->
<div id="view-plans" class="view-section">
    <div class="section-header">
        <div>
            <h3 class="section-title">Gói dịch vụ</h3>
            <p class="section-subtitle">Quản lý gói đăng ký, giá cả và tính năng</p>
        </div>
        <button id="btn-add-plan" class="btn-primary" style="padding: 8px 16px;">
            <i class="fa-solid fa-plus"></i> Gói mới
        </button>
    </div>

    <div id="plans-grid" class="plans-grid">
        <!-- Populated by JS -->
    </div>
</div>

<!-- ════════════════════════════════════
                         SCREEN 6: ADMIN PROFILE & SETTINGS
                         ════════════════════════════════════ -->
<div id="view-settings" class="view-section">

    <div class="section-header">
        <div>
            <h3 class="section-title">Thông tin cá nhân và cài đặt</h3>
            <p class="section-subtitle">Quản lý thông tin cá nhân và cấu hình hệ thống</p>
        </div>
    </div>

    <div class="settings-grid">

        <!-- Profile Card -->
        <div class="glass-card booth-panel">
            <div class="flex-between mb-6"
                 style="border-bottom:1px solid var(--border); padding-bottom:16px;">
                <div class="booth-panel-title" style="margin-bottom:0;">
                    <i class="fa-solid fa-user-shield"></i> Thông tin cá nhân
                </div>
                <button id="btn-edit-profile" class="btn-ghost" style="font-size:12px;">
                    <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa
                </button>
                <div id="profile-edit-actions" class="hidden"
                     style="display:flex; align-items:center; gap:10px;">
                    <button id="btn-cancel-profile" class="btn-ghost"
                            style="font-size:12px;">
                        Hủy
                    </button>
                    <button id="btn-save-profile" class="btn-primary" style="font-size:12px;">
                        <i class="fa-solid fa-floppy-disk"></i> Lưu
                    </button>
                </div>
            </div>

            <!-- Avatar + Name -->
            <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px;">
                <div class="profile-avatar-wrapper">
                    <img id="profile-avatar-preview" src="https://i.pravatar.cc/150?img=11"
                         class="profile-avatar" alt="Admin Avatar">
                    <input type="file" id="profile-avatar-input" accept="image/*" class="hidden">
                    <div id="profile-avatar-overlay" class="profile-avatar-overlay">
                        <i class="fa-solid fa-camera"></i>
                    </div>
                </div>
                <div style="flex:1;">
                    <label class="form-label">Họ và tên</label>
                    <input type="text" id="set-name" value="Admin"
                           class="form-input profile-editable" disabled>
                </div>
            </div>

            <!-- Email (always read-only) -->
            <div class="mb-4">
                <label class="form-label">Email (Emergent Login)</label>
                <input type="email" id="set-email" value="admin@audiotravelling.com"
                       class="form-input" disabled style="opacity:0.5; cursor:not-allowed;">
            </div>

            <!-- Phone -->
            <div class="mb-4">
                <label class="form-label">Số điện thoại</label>
                <input type="tel" id="set-phone" value="+84 123 456 789"
                       class="form-input profile-editable" disabled>
            </div>

            <!-- Bio -->
            <div>
                <label class="form-label">Thông tin </label>
                <textarea id="set-bio" class="form-input profile-editable" rows="3"
                          disabled>Quản lý hội chợ phụ trách việc sắp xếp gian hàng, thuyết minh âm thanh và theo dõi hoa hồng cho các sự kiện của Audio Travelling.</textarea>
            </div>
        </div>

        <!-- Social Login + Tier Configuration -->
        <div style="display:flex; flex-direction:column; gap:20px;">

            <!-- Emergent Social Login Status -->
            <div class="glass-card booth-panel">
                <div class="booth-panel-title">
                    <i class="fa-solid fa-link"></i> Đăng nhập Emergent
                </div>
                <div style="display:flex; align-items:center; gap:16px; margin-bottom:16px;">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg"
                         style="width:32px; height:32px;" alt="Google">
                    <div style="flex:1;">
                        <p style="font-weight:600; font-size:14px;">Tài khoản Google</p>
                        <p style="font-size:12px; color:var(--text-muted);">
                            admin@audiotravelling.com
                        </p>
                    </div>
                    <div id="social-status" class="social-login-badge connected">
                        <i class="fa-solid fa-circle-check"></i> Đã kết nối
                    </div>
                </div>
                <p style="font-size:12px; color:var(--text-dim); line-height:1.6;">
                    Tài khoản Google của bạn được liên kết thông qua nền tảng Emergent Social Login. Quá trình xác thực được xử lý bảo mật qua OAuth 2.0.
                </p>
            </div>

            <!-- Tier Commission Configuration -->
            <div class="glass-card booth-panel">
                <div class="booth-panel-title">
                    <i class="fa-solid fa-sliders"></i> Tỷ lệ hoa hồng theo gói
                </div>

                <!-- Basic Tier -->
                <div class="tier-config-card">
                    <div class="tier-config-header">
                        <span class="tier-badge tier-basic">
                            <i class="fa-solid fa-circle"
                               style="font-size:6px;"></i> GÓI CƠ BẢN
                        </span>
                    </div>
                    <div class="tier-config-inputs">
                        <div>
                            <label class="form-label">Tỷ lệ (R<sub>c</sub>)</label>
                            <input type="number" step="0.01" id="rc-basic" value="0.10"
                                   class="form-input mono" min="0" max="1">
                        </div>
                        <div>
                            <label class="form-label">Phí (F) VNĐ</label>
                            <input type="number" step="0.01" id="fee-basic" value="35000"
                                   class="form-input mono" min="0">
                        </div>
                    </div>
                </div>

                <!-- Gold Tier -->
                <div class="tier-config-card">
