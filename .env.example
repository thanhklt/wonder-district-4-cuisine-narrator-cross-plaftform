# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_DB=audiotravelling
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password
POSTGRES_PORT=5432

# ─── API Service (C#) ─────────────────────────────────────
API_PORT=5000
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRY_HOURS=24
SESSION_EXPIRY_HOURS=24

# Connection string (used inside docker network)
DATABASE_URL=Host=postgres;Database=audiotravelling;Username=postgres;Password=your_strong_password

# ─── VNPay ────────────────────────────────────────────────
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/callback

# ─── DeepTranslate Service (Python) ──────────────────────
DEEP_TRANSLATE_PORT=8000
DEEP_TRANSLATE_URL=http://deep-translate:8000

# ─── TTS Service (Python) ────────────────────────────────
TTS_PORT=8001
TTS_URL=http://tts:8001
AUDIO_STORAGE_PATH=/storage/audio

# ─── Mobile PWA ──────────────────────────────────────────
MOBILE_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_MAPS_TILE=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ─── WebApp (Admin/Owner) ────────────────────────────────
WEBAPP_PORT=3001
NEXT_PUBLIC_WEBAPP_API_URL=http://localhost:5000
