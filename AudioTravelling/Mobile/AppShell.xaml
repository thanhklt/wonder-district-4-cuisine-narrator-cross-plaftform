<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Mobile.Views"
    Shell.FlyoutBehavior="Disabled">


    <TabBar>

        <!-- Tab 1: Bản đồ -->
        <Tab Title="Bản Đồ" Icon="tab_map.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:MainPage}"
                Route="MainPage"/>
        </Tab>

        <!-- Tab 2: Đặt món -->
        <Tab Title="Đặt món" Icon="tab_order.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:OrderPage}"
                Route="OrderPage"/>
        </Tab>

        <!-- Tab 3: Audio -->
        <Tab Title="Audio" Icon="tab_audio.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:AudioPlayerPage}"
                Route="AudioPlayerPage"/>
        </Tab>

        <!-- Tab 4: Cài đặt -->
        <Tab Title="Cài đặt" Icon="tab_settings.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:SettingsPage}"
                Route="SettingsPage"/>
        </Tab>

    </TabBar>
</Shell>