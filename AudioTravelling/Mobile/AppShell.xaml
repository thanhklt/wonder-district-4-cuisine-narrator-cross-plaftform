<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Mobile.Views"
    Shell.FlyoutBehavior="Disabled">

    <Shell.Resources>
        <!-- Tab bar brand styling -->
        <Style TargetType="Shell" ApplyToDerivedTypes="True">
            <Setter Property="Shell.TabBarBackgroundColor"   Value="White"/>
            <Setter Property="Shell.TabBarForegroundColor"   Value="#10B981"/>
            <Setter Property="Shell.TabBarTitleColor"        Value="#10B981"/>
            <Setter Property="Shell.TabBarUnselectedColor"   Value="#94A3B8"/>
        </Style>
    </Shell.Resources>

    <TabBar>

        <!-- Tab 1: Bản đồ -->
        <Tab Title="Bản Đồ" Icon="tab_map.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:MainPage}"
                Route="MainPage"/>
        </Tab>

        <!-- Tab 2: Đặt món -->
        <Tab Title="Đặt món" Icon="tab_order.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:OrderPage}"
                Route="OrderPage"/>
        </Tab>

        <!-- Tab 3: Cài đặt -->
        <Tab Title="Cài đặt" Icon="tab_settings.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:SettingsPage}"
                Route="SettingsPage"/>
        </Tab>

    </TabBar>
</Shell>