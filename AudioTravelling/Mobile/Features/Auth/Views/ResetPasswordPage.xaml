<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AudioTravelling.Mobile.Features.Auth.Views.ResetPasswordPage"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0">
            <Grid Padding="24,40,24,0">
                <Label Text="&#xf053;" FontFamily="FA6Solid" FontSize="20" TextColor="#0F172A" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackToLoginTapped"/></Label.GestureRecognizers>
                </Label>
            </Grid>

            <VerticalStackLayout Spacing="0" Padding="24,32,24,0">
                <Label Text="Tạo mật khẩu mới" HorizontalOptions="Center" FontFamily="OpenSans-Semibold" FontSize="24" TextColor="Black" Margin="0,0,0,8"/>
                <Label Text="Vui lòng nhập mật khẩu mới cho tài khoản của bạn." HorizontalOptions="Center" HorizontalTextAlignment="Center" FontFamily="OpenSans-Regular" FontSize="14" TextColor="Black" Margin="0,0,0,32"/>

                <Label Text="Mật khẩu mới" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="#475569" Margin="0,0,0,6"/>
                <Border StrokeShape="RoundRectangle 14" Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="16,0" HeightRequest="52">
                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Opacity="0.04" Radius="6"/></Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="&#xF023;" FontFamily="FA6Solid" FontSize="15" TextColor="#94A3B8" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="EntryNewPassword" Placeholder="Mật khẩu mới (ít nhất 6 ký tự)" PlaceholderColor="#CBD5E1" IsPassword="True" TextColor="#0F172A" FontSize="15" FontFamily="OpenSans-Regular" BackgroundColor="Transparent" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Label x:Name="LblNewPasswordError" Text="" FontSize="12" TextColor="#EF4444" FontFamily="OpenSans-Regular" Margin="4,4,0,0" IsVisible="False"/>

                <Label Text="Xác nhận mật khẩu mới" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="#475569" Margin="0,16,0,6"/>
                <Border StrokeShape="RoundRectangle 14" Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="16,0" HeightRequest="52">
                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Opacity="0.04" Radius="6"/></Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="&#xF023;" FontFamily="FA6Solid" FontSize="15" TextColor="#94A3B8" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="EntryConfirmPassword" Placeholder="Nhập lại mật khẩu mới" PlaceholderColor="#CBD5E1" IsPassword="True" TextColor="#0F172A" FontSize="15" FontFamily="OpenSans-Regular" BackgroundColor="Transparent" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Label x:Name="LblConfirmPasswordError" Text="" FontSize="12" TextColor="#EF4444" FontFamily="OpenSans-Regular" Margin="4,4,0,0" IsVisible="False"/>

                <Label x:Name="LblGeneralError" Text="" FontSize="13" TextColor="#EF4444" FontFamily="OpenSans-Semibold" HorizontalOptions="Center" Margin="0,16,0,0" IsVisible="False"/>

                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent" Margin="0,32,0,0" HeightRequest="54">
                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#008dd4" Offset="0.0"/><GradientStop Color="#008dd4" Offset="1.0"/></LinearGradientBrush></Border.Background>
                    <Border.Shadow><Shadow Brush="#000000" Offset="0,6" Opacity="0.35" Radius="12"/></Border.Shadow>
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnUpdatePasswordTapped"/></Border.GestureRecognizers>
                    <Label Text="Tạo mật khẩu" FontFamily="OpenSans-Semibold" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
