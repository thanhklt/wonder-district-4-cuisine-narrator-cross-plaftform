<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AudioTravelling.Mobile.Features.Auth.Views.ForgotPasswordPage"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0">
            <Grid Padding="24,40,24,0">
                <Label Text="&#xf053;" FontFamily="FA6Solid" FontSize="20" TextColor="#0F172A" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackToLoginTapped"/></Label.GestureRecognizers>
                </Label>
            </Grid>

            <VerticalStackLayout Spacing="0" Padding="24,32,24,0">
                <Label Text="Quên mật khẩu" HorizontalOptions="Center" FontFamily="OpenSans-Semibold" FontSize="28" TextColor="Black" Margin="0,0,0,8"/>
                <Label Text="Nhập email đã đăng ký tài khoản của bạn để nhận liên kết khôi phục mật khẩu." HorizontalOptions="Center" HorizontalTextAlignment="Center" FontFamily="OpenSans-Regular" FontSize="16" TextColor="Black" Margin="0,0,0,32"/>

                <Label Text="Email" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="Black" Margin="0,0,0,6"/>
                <Border StrokeShape="RoundRectangle 14" Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="16,0" HeightRequest="52">
                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Opacity="0.04" Radius="6"/></Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="&#xF0E0;" FontFamily="FA6Solid" FontSize="15" TextColor="#E27D60" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="EntryEmail" Placeholder="your@email.com" PlaceholderColor="#CBD5E1" Keyboard="Email" TextColor="#0F172A" FontSize="15" FontFamily="OpenSans-Regular" BackgroundColor="Transparent" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Label x:Name="LblEmailError" Text="" FontSize="12" TextColor="#EF4444" FontFamily="OpenSans-Regular" Margin="4,4,0,0" IsVisible="False"/>

                <Label x:Name="LblGeneralError" Text="" FontSize="13" TextColor="#EF4444" FontFamily="OpenSans-Semibold" HorizontalOptions="Center" Margin="0,16,0,0" IsVisible="False"/>

                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent" Margin="0,32,0,0" HeightRequest="54">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E27D60" Offset="0.0"/>
                            <GradientStop Color="#E27D60" Offset="1.0"/></LinearGradientBrush></Border.Background>
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnSendResetLinkTapped"/></Border.GestureRecognizers>
                    <Label Text="Gửi liên kết khôi phục" FontFamily="OpenSans-Semibold" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
