<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AudioTravelling.Mobile.Features.Auth.Views.LoginPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0">

            <Image Source="logo_cty.jpg"
                   HorizontalOptions="Center"
                   WidthRequest="130"
                   HeightRequest="130"
                   Margin="0,80,0,40" />

            <VerticalStackLayout Spacing="0" Padding="24,32,24,0">

                <Label Text="Đăng nhập"
                       HorizontalOptions="Center"
                       FontFamily="OpenSans-Semibold"
                       FontSize="32"
                       TextColor="Black"
                       Margin="0,0,0,24" />

                <Label Text="Email"
                       FontFamily="OpenSans-Semibold"
                       FontSize="13"
                       TextColor="Black"
                       Margin="0,0,0,6" />

                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="16,0"
                        HeightRequest="52">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Opacity="0.04"
                                Radius="6" />
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="&#xF0E0;"
                               FontFamily="FA6Solid"
                               FontSize="15"
                               TextColor="#E27D60"
                               VerticalOptions="Center" />

                        <Entry Grid.Column="1"
                               Placeholder="your@email.com"
                               PlaceholderColor="#CBD5E1"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               TextColor="#0F172A"
                               FontSize="15"
                               FontFamily="OpenSans-Regular"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Label Text="{Binding EmailError}"
                       FontSize="12"
                       TextColor="#EF4444"
                       FontFamily="OpenSans-Regular"
                       Margin="4,4,0,0"
                       IsVisible="{Binding HasEmailError}" />

                <Label Text="Mật khẩu"
                       FontFamily="OpenSans-Semibold"
                       FontSize="13"
                       TextColor="Black"
                       Margin="0,16,0,6" />

                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="16,0"
                        HeightRequest="52">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,2"
                                Opacity="0.04"
                                Radius="6" />
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="&#xF023;"
                               FontFamily="FA6Solid"
                               FontSize="15"
                               TextColor="#E27D60"
                               VerticalOptions="Center" />

                        <Entry Grid.Column="1"
                               Placeholder="Ít nhất 6 ký tự"
                               PlaceholderColor="#CBD5E1"
                               IsPassword="True"
                               Text="{Binding Password}"
                               TextColor="#0F172A"
                               FontSize="15"
                               FontFamily="OpenSans-Regular"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Label Text="{Binding PasswordError}"
                       FontSize="12"
                       TextColor="#EF4444"
                       FontFamily="OpenSans-Regular"
                       Margin="4,4,0,0"
                       IsVisible="{Binding HasPasswordError}" />

                <Label Text="Quên mật khẩu?"
                       FontFamily="OpenSans-Semibold"
                       FontSize="13"
                       TextColor="Black"
                       HorizontalOptions="End"
                       Margin="0,12,0,0"
                       FontAttributes="Bold"
                       TextDecorations="Underline">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnForgotPasswordTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label Text="{Binding GeneralError}"
                       FontSize="13"
                       TextColor="#EF4444"
                       FontFamily="OpenSans-Semibold"
                       HorizontalOptions="Center"
                       Margin="0,16,0,0"
                       IsVisible="{Binding HasGeneralError}" />

                <Border StrokeShape="RoundRectangle 16"
                        Stroke="Transparent"
                        Margin="0,24,0,0"
                        HeightRequest="54">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E27D60" Offset="0.0" />
                            <GradientStop Color="#E27D60" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Border.Shadow>
                        <Shadow Brush="#000000"
                                Offset="0,6"
                                Opacity="0.35"
                                Radius="12" />
                    </Border.Shadow>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LoginCommand}" />
                    </Border.GestureRecognizers>

                    <Grid>
                        <Label Text="Đăng nhập"
                               FontFamily="OpenSans-Semibold"
                               FontSize="16"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           Margin="0,0,16,0"
                                           Color="White" />
                    </Grid>
                </Border>

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Margin="0,24,0,40"
                                       Spacing="4">
                    <Label Text="Chưa có tài khoản?"
                           FontFamily="OpenSans-Regular"
                           FontSize="14"
                           TextColor="#94A3B8"
                           VerticalOptions="Center" />

                    <Label x:Name="LblRegisterLink"
                           Text="Đăng ký ngay"
                           TextDecorations="Underline"
                           FontFamily="OpenSans-Semibold"
                           FontSize="14"
                           TextColor="#000000"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegisterLinkTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>