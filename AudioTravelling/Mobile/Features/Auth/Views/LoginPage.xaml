<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AudioTravelling.Mobile.Features.Auth.Views.LoginPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0">

            <!-- ── GREEN HEADER ── -->
            <Image Source="logo_cty.jpg" HorizontalOptions="Center" WidthRequest="150" HeightRequest="150" Margin="0,80,0,40" />

            <!-- ── LOGIN FORM ── -->
            <VerticalStackLayout Spacing="0" Padding="24,32,24,0">

                <Label Text="Đăng nhập" HorizontalOptions="Center" FontFamily="OpenSans-Semibold" FontSize="24" TextColor="#0F172A" Margin="0,0,0,24"/>

                <!-- Email -->
                <Label Text="Email" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="#475569" Margin="0,0,0,6"/>
                <Border StrokeShape="RoundRectangle 14" Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="16,0" HeightRequest="52">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.04" Radius="6"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="&#xF0E0;" FontFamily="FA6Solid" FontSize="15" TextColor="#94A3B8" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="EntryEmail" Placeholder="your@email.com" PlaceholderColor="#CBD5E1"
                               Keyboard="Email" TextColor="#0F172A" FontSize="15" FontFamily="OpenSans-Regular" BackgroundColor="Transparent" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Label x:Name="LblEmailError" Text="" FontSize="12" TextColor="#EF4444" FontFamily="OpenSans-Regular" Margin="4,4,0,0" IsVisible="False"/>

                <!-- Password -->
                <Label Text="Mật khẩu" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="#475569" Margin="0,16,0,6"/>
                <Border StrokeShape="RoundRectangle 14" Stroke="#E2E8F0" StrokeThickness="1" BackgroundColor="White" Padding="16,0" HeightRequest="52">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.04" Radius="6"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="&#xF023;" FontFamily="FA6Solid" FontSize="15" TextColor="#94A3B8" VerticalOptions="Center"/>
                        <Entry Grid.Column="1" x:Name="EntryPassword" Placeholder="Ít nhất 6 ký tự" PlaceholderColor="#CBD5E1"
                               IsPassword="True" TextColor="#0F172A" FontSize="15" FontFamily="OpenSans-Regular" BackgroundColor="Transparent" VerticalOptions="Center"/>
                    </Grid>
                </Border>
                <Label x:Name="LblPasswordError" Text="" FontSize="12" TextColor="#EF4444" FontFamily="OpenSans-Regular" Margin="4,4,0,0" IsVisible="False"/>

                <!-- Forgot password link -->
                <Label Text="Quên mật khẩu?" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="Black" HorizontalOptions="End" Margin="0,12,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnForgotPasswordTapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <!-- Error message -->
                <Label x:Name="LblGeneralError" Text="" FontSize="13" TextColor="#EF4444" FontFamily="OpenSans-Semibold"
                       HorizontalOptions="Center" Margin="0,16,0,0" IsVisible="False"/>

                <!-- Login button -->
                <Border StrokeShape="RoundRectangle 16" Stroke="Transparent" Margin="0,24,0,0" HeightRequest="54">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#008dd4" Offset="0.0"/>
                            <GradientStop Color="#008dd4" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,6" Opacity="0.35" Radius="12"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Đăng nhập" FontFamily="OpenSans-Semibold" FontSize="16" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <!-- Register link -->
                <HorizontalStackLayout HorizontalOptions="Center" Margin="0,24,0,40" Spacing="4">
                    <Label Text="Chưa có tài khoản?" FontFamily="OpenSans-Regular" FontSize="14" TextColor="#94A3B8" VerticalOptions="Center"/>
                    <Label x:Name="LblRegisterLink" Text="Đăng ký ngay" FontFamily="OpenSans-Semibold" FontSize="14" TextColor="#000000" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegisterLinkTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
