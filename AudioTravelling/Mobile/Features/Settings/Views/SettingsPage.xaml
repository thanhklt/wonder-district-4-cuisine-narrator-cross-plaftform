<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AudioTravelling.Mobile.Features.Settings.Views.SettingsPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── USER PROFILE CARD ── -->
            <Border
                StrokeShape="RoundRectangle 20"
                Stroke="#E2E8F0"
                StrokeThickness="1"
                BackgroundColor="White"
                Margin="16,20,16,0"
                Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.06" Radius="12"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnUserProfileTapped"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <!-- Avatar circle -->
                    <Border
                        Grid.Column="0"
                        StrokeShape="RoundRectangle 28"
                        Stroke="Transparent"
                        WidthRequest="56" HeightRequest="56">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="White" Offset="0.0"/>
                                <GradientStop Color="White" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label
                            x:Name="LblAvatar"
                            Text="T"
                            FontFamily="OpenSans-Semibold"
                            FontSize="24"
                            TextColor="Black"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label x:Name="LblUserName" Text="Người dùng" FontFamily="OpenSans-Semibold" FontSize="16" TextColor="Black"/>
                        <Label x:Name="LblUserEmail" Text="user@email.com" FontFamily="OpenSans-Regular" FontSize="12" TextColor="Black"/>
                    </VerticalStackLayout>

                    <Label Grid.Column="2" Text="&#xF054;" FontFamily="FA6Solid" FontSize="14" TextColor="Black" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ── SECTION: Âm thanh ── -->
            <Label Text="Hướng dẫn âm thanh" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="Black" Margin="20,24,20,8"/>

            <Border
                StrokeShape="RoundRectangle 20"
                Stroke="#E2E8F0"
                StrokeThickness="1"
                BackgroundColor="White"
                Margin="16,0"
                Padding="20,4">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">

                    <!-- Audio master toggle -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" Padding="0,14" HeightRequest="60">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" Stroke="Transparent" BackgroundColor="#008dd4" WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xF028;" FontFamily="FA6Solid" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Phát âm thanh tự động" FontFamily="OpenSans-Semibold" FontSize="14" TextColor="#0F172A"/>
                            <Label x:Name="LblAudioStatus" Text="Đang bật – phát khi đến gần POI" FontFamily="OpenSans-Regular" FontSize="12" TextColor="#10B981"/>
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="2"
                            x:Name="AudioToggle"
                            IsToggled="True"
                            OnColor="#10B981"
                            ThumbColor="#dedede"
                            VerticalOptions="Center"
                            Toggled="OnAudioToggled"/>
                    </Grid>

                    <BoxView Color="#F1F5F9" HeightRequest="1" Margin="56,0,0,0"/>

                    <BoxView Color="#F1F5F9" HeightRequest="1" Margin="56,0,0,0"/>

                    <!-- Language -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" Padding="0,14" HeightRequest="60">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" Stroke="Transparent" BackgroundColor="#FFEDD5" WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xF1AB;" FontFamily="FA6Solid" FontSize="18" TextColor="#F97316" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Ngôn ngữ hướng dẫn" FontFamily="OpenSans-Semibold" FontSize="14" TextColor="#0F172A"/>
                        </VerticalStackLayout>
                        
                        <!-- Segmented language picker -->
                        <Label Grid.Column="2" Text="&#xF054;" FontFamily="FA6Solid" FontSize="14" TextColor="#0F172A" VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ── SECTION: Bản đồ ── -->
            <Label Text="Bản đồ &amp; Định vị" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="Black" Margin="20,24,20,8"/>

            <Border
                StrokeShape="RoundRectangle 20"
                Stroke="#E2E8F0"
                StrokeThickness="1"
                BackgroundColor="White"
                Margin="16,0"
                Padding="20,4">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" Padding="0,14" HeightRequest="60">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" Stroke="Transparent" BackgroundColor="#008dd4" WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xF3C5;" FontFamily="FA6Solid" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Bán kính quét POI" FontFamily="OpenSans-Semibold" FontSize="14" TextColor="#0F172A"/>
                            <Label Text="1 km (Cố định)" FontFamily="OpenSans-Regular" FontSize="12" TextColor="Black"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView Color="#F1F5F9" HeightRequest="1" Margin="56,0,0,0"/>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" Padding="0,14" HeightRequest="60">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" Stroke="Transparent" BackgroundColor="#D1FAE5" WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xf5a0;" FontFamily="FA6Solid" FontSize="18" TextColor="#10B981" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Loại bản đồ" FontFamily="OpenSans-Semibold" FontSize="14" TextColor="Black"/>
                            <Label Text="Street (Đường phố)" FontFamily="OpenSans-Regular" FontSize="12" TextColor="Black"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="&#xF054;" FontFamily="FA6Solid" FontSize="14" TextColor="Black" VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ── APP INFO ── -->
            <Label Text="Thông tin ứng dụng" FontFamily="OpenSans-Semibold" FontSize="13" TextColor="Black" Margin="20,24,20,8"/>

            <Border
                StrokeShape="RoundRectangle 20"
                Stroke="#E2E8F0"
                StrokeThickness="1"
                BackgroundColor="White"
                Margin="16,0,16,40"
                Padding="20,4">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="8"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" Padding="0,16">
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 12" Stroke="Transparent" BackgroundColor="#F1F5F9" WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xF05A;" FontFamily="FA6Solid" FontSize="18" TextColor="#64748B" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Dotonbori Audio Travel" FontFamily="OpenSans-Semibold" FontSize="14" TextColor="Black"/>
                            <Label Text="Phiên bản 1.0.0 • Build 2026.03" FontFamily="OpenSans-Regular" FontSize="12" TextColor="Black"/>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ── LOGOUT BUTTON ── -->
            <Border
                StrokeShape="RoundRectangle 16"
                Stroke="#FEE2E2"
                StrokeThickness="1.5"
                BackgroundColor="#FEF2F2"
                Margin="16,24,16,40"
                Padding="16">
                <Border.Shadow>
                    <Shadow Brush="#EF4444" Offset="0,4" Opacity="0.10" Radius="10"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Label Text="&#xF2F5;" FontFamily="FA6Solid" FontSize="16" TextColor="#EF4444" VerticalOptions="Center"/>
                    <Label Text="Đăng xuất" FontFamily="OpenSans-Semibold" FontSize="15" TextColor="#EF4444" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
