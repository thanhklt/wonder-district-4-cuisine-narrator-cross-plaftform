<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AudioTravelling.Mobile.Features.Poi.ViewModels"
    x:Class="AudioTravelling.Mobile.Features.Poi.Views.PoiListPage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F1F5F9">

    <ContentPage.BindingContext>
        <!-- Injected via constructor in code-behind -->
    </ContentPage.BindingContext>

    <RefreshView
        IsRefreshing="{Binding IsRefreshing}"
        Command="{Binding RefreshCommand}">

        <CollectionView
            ItemsSource="{Binding Pois}"
            SelectionMode="None">

            <!-- ── Header ───────────────────────────────────────────────── -->
            <CollectionView.Header>
                <VerticalStackLayout Padding="16,52,16,8" Spacing="4">
                    <Label
                        Text="Explore Places"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#0F172A"/>
                    <Label
                        Text="Discover points of interest near you"
                        FontSize="13"
                        TextColor="#64748B"/>
                </VerticalStackLayout>
            </CollectionView.Header>

            <!-- ── Empty state ──────────────────────────────────────────── -->
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="12"
                    Padding="32">
                    <Label
                        Text="🗺️"
                        FontSize="56"
                        HorizontalOptions="Center"/>
                    <Label
                        Text="No POIs available"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#334155"
                        HorizontalOptions="Center"/>
                    <Label
                        Text="Check back later for new places."
                        FontSize="13"
                        TextColor="#94A3B8"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <!-- ── Items layout ─────────────────────────────────────────── -->
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>

            <!-- ── Item template ────────────────────────────────────────── -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        StrokeShape="RoundRectangle 16"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Margin="16,0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Opacity="0.07" Radius="12"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="0">

                            <!-- Cover image -->
                            <Border
                                StrokeShape="RoundRectangle 16,16,0,0"
                                Stroke="Transparent"
                                HeightRequest="180"
                                HorizontalOptions="Fill">
                                <Image
                                    Source="{Binding ImageUrl}"
                                    Aspect="AspectFill"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"/>
                            </Border>

                            <!-- Card content -->
                            <VerticalStackLayout Padding="14,12,14,14" Spacing="6">

                                <!-- Name -->
                                <Label
                                    Text="{Binding Name}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="#0F172A"
                                    LineBreakMode="TailTruncation"/>

                                <!-- Address -->
                                <HorizontalStackLayout Spacing="4">
                                    <Label
                                        Text="📍"
                                        FontSize="11"
                                        VerticalOptions="Center"/>
                                    <Label
                                        Text="{Binding Address}"
                                        FontSize="12"
                                        TextColor="#64748B"
                                        LineBreakMode="TailTruncation"
                                        HorizontalOptions="Fill"/>
                                </HorizontalStackLayout>

                                <!-- Description -->
                                <Label
                                    Text="{Binding Description}"
                                    FontSize="13"
                                    TextColor="#475569"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="2"
                                    Margin="0,2,0,0"/>

                                <!-- View Details button -->
                                <Border
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    BackgroundColor="#0F172A"
                                    Padding="0,10"
                                    Margin="0,6,0,0"
                                    HorizontalOptions="Fill">
                                    <Border.Shadow>
                                        <Shadow Brush="#0F172A" Offset="0,4" Opacity="0.30" Radius="8"/>
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenDetailCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Label
                                        Text="View Details"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="White"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                                </Border>

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Footer spacing -->
            <CollectionView.Footer>
                <BoxView HeightRequest="24" Color="Transparent"/>
            </CollectionView.Footer>

        </CollectionView>
    </RefreshView>

</ContentPage>