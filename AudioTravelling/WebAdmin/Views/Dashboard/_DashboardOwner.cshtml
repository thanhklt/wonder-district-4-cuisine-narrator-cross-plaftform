<!-- ════════════════════════════════════
     SCREEN 1: DASHBOARD OVERVIEW (OWNER)
     ════════════════════════════════════ -->
<div id="view-dashboard-owner" class="view-section">

    <!-- Stats Row -->
    <div class="grid-4 mb-6">
        <div class="glass-card stat-card">
            <div class="stat-icon amber"><i class="fa-solid fa-coins"></i></div>
            <div>
                <p class="stat-label">Tổng doanh thu</p>
                <p class="stat-value" id="stat-revenue-owner">0 ₫</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
            <div>
                <p class="stat-label">Số lượng đơn hàng giao thành công</p>
                <p class="stat-value" id="stat-success-owner">0</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon amber"><i class="fa-solid fa-hourglass-half"></i></div>
            <div>
                <p class="stat-label">Số lượng đơn hàng đang xử lý</p>
                <p class="stat-value" id="stat-pending-owner">0</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon red"><i class="fa-solid fa-ban"></i></div>
            <div>
                <p class="stat-label">Số lượng đơn hàng bị hủy</p>
                <p class="stat-value" id="stat-cancelled-owner">0</p>
            </div>
        </div>
    </div>

    <!-- Revenue Chart + Activity -->
    <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px; margin-bottom:24px;">
        <div class="glass-card" style="padding:24px;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:8px;">
                <i class="fa-solid fa-chart-line text-accent" style="margin-right:8px;"></i>Thống kê
                doanh thu
            </h3>

            <!-- Controls: timeframe selector + date range -->
            <div class="section-controls" style="display:flex; align-items:center; gap:12px; margin-bottom:12px; flex-wrap:wrap;">
                <div class="timeframe-tabs" style="display:flex; gap:8px; align-items:center;">
                    <label for="timeframe-select-owner" style="margin:0; font-size:13px; color:var(--text-muted); margin-right:6px;">Theo:</label>
                    <select id="timeframe-select-owner" class="form-input" style="padding:8px 10px; width:140px;">
                        <option value="day">Ngày</option>
                        <option value="week">Tuần</option>
                        <option value="month">Tháng</option>
                        <option value="year">Năm</option>
                    </select>
                </div>

                <!-- Move date inputs to the right of the timeframe tabs -->
                <div id="date-range-controls-owner" style="margin-left:auto; display:flex; align-items:center; gap:8px;">
                    <label class="form-label" style="margin:0 6px 0 0; font-size:12px;">Từ</label>
                    <input id="filter-from-owner" type="date" class="form-input" style="padding:8px 10px; width:150px;" />
                    <label class="form-label" style="margin:0 6px 0 0; font-size:12px;">Đến</label>
                    <input id="filter-to-owner" type="date" class="form-input" style="padding:8px 10px; width:150px;" />
                    <button id="btn-filter-owner" type="button" class="btn-primary" style="margin-left:6px;">Tìm kiếm</button>
                </div>
            </div>

            <div class="chart-wrapper">
                <canvas id="revenueChart-owner"></canvas>
            </div>
        </div>

        <div class="glass-card" style="padding:24px;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-bolt text-accent" style="margin-right:8px;"></i>Hoạt động gần
                đây
            </h3>
            <div id="activity-list-owner">
                <!-- Injected by JS -->
            </div>
        </div>
    </div>
</div>
