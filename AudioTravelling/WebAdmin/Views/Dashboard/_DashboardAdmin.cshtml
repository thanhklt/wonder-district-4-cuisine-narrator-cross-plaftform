<!-- Admin Dashboard -->
<div id="view-dashboard-admin" class="view-section">

    <!-- Stats Row -->
    <div class="grid-4 mb-6">
        <div class="glass-card stat-card-admin">
            <div class="stat-icon green"><i class="fa-solid fa-users"></i></div>
            <p class="stat-label">Người dùng đang hoạt động</p>
            <p class="stat-value" id="stat-active-users">0</p>
        </div>
        <div class="glass-card stat-card-admin">
            <div class="stat-icon red"><i class="fa-solid fa-ban"></i></div>
            <p class="stat-label">POI bị từ chối</p>
            <p class="stat-value" id="stat-total-scans">0</p>
        </div>
        <div class="glass-card stat-card-admin">
            <div class="stat-icon purple"><i class="fa-solid fa-map-pin"></i></div>
            <p class="stat-label">Tổng số POI đã duyệt</p>
            <p class="stat-value" id="stat-total-pois">0</p>
        </div>
        <div class="glass-card stat-card-admin">
            <div class="stat-icon amber"><i class="fa-solid fa-hourglass-half"></i></div>
            <p class="stat-label">POI chờ duyệt</p>
            <p class="stat-value" id="stat-pending-pois">0</p>
        </div>
    </div>
</div>
