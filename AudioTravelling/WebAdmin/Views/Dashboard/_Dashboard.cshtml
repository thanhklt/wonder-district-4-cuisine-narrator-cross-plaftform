<!-- ════════════════════════════════════
     SCREEN 1: DASHBOARD OVERVIEW
     ════════════════════════════════════ -->
<div id="view-dashboard" class="view-section active">

    <!-- Stats Row -->
    <div class="grid-4 mb-6">
        <div class="glass-card stat-card">
            <div class="stat-icon green"><i class="fa-solid fa-tent"></i></div>
            <div>
                <p class="stat-label">Tổng số hội chợ</p>
                <p class="stat-value" id="stat-fairs">0</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon blue"><i class="fa-solid fa-store"></i></div>
            <div>
                <p class="stat-label">Số lượng gian hàng đang hoạt động</p>
                <p class="stat-value" id="stat-booths">0</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon amber"><i class="fa-solid fa-dollar-sign"></i></div>
            <div>
                <p class="stat-label">Tổng doanh thu</p>
                <p class="stat-value" id="stat-revenue">0 ₫</p>
            </div>
        </div>
        <div class="glass-card stat-card">
            <div class="stat-icon purple"><i class="fa-solid fa-users"></i></div>
            <div>
                <p class="stat-label">Tổng khách hàng</p>
                <p class="stat-value" id="stat-visitors">0</p>
            </div>
        </div>
    </div>

    <!-- Revenue Chart + Activity -->
    <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px; margin-bottom:24px;">
        <div class="glass-card" style="padding:24px;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-chart-line text-accent" style="margin-right:8px;"></i>Thống kê
                doanh thu
            </h3>
            <div class="chart-wrapper">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <div class="glass-card" style="padding:24px;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-bolt text-accent" style="margin-right:8px;"></i>Hoạt động gần
                đây
            </h3>
            <div id="activity-list">
                <!-- Injected by JS -->
            </div>
        </div>
    </div>

    <!-- Priority Leaderboard -->
    <div class="glass-card" style="padding:24px;">
        <div class="flex-between mb-4">
            <h3 style="font-size:16px; font-weight:700;">
                <i class="fa-solid fa-trophy text-accent" style="margin-right:8px;"></i>Bảng xếp
                hạng độ ưu tiên của gian hàng
            </h3>

        </div>
        <table class="leaderboard-table" id="leaderboard-table">
            <thead>
                <tr>
                    <th style="width:60px;">Số thứ tự</th>
                    <th>Tên gian hàng</th>
                    <th>Công ty</th>
                    <th>Hạng</th>
                    <th>Đơn hàng</th>
                    <th style="text-align:right;">Điểm ưu tiên</th>
                </tr>
            </thead>
            <tbody id="leaderboard-body">
                <!-- Injected by JS -->
            </tbody>
        </table>
    </div>
</div>
