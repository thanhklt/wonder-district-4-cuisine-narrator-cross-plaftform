<!-- ════════════════════════════════════
     SCREEN 2: BOOTH MANAGER
     ════════════════════════════════════ -->
<div id="view-booths" class="view-section">

    <!-- Top Bar -->
    <div class="flex-between mb-4">
        <div>
            <h3 class="section-title">Quản lý gian hàng</h3>
            <p class="section-subtitle">Quản lý gian hàng, thuyết minh âm thanh và bán kính</p>
        </div>
        <div style="display:flex; gap:10px;">
            <button id="btn-add-booth" class="btn-primary btn-ripple">
                <i class="fa-solid fa-plus"></i> Thêm gian hàng
            </button>
            <button id="btn-save-booth" class="btn-primary btn-ripple">
                <i class="fa-solid fa-floppy-disk"></i> Lưu gian hàng
            </button>
        </div>
    </div>

    <!-- Split View -->
    <div class="booth-split">

        <!-- LEFT: Booth List -->
        <div class="glass-card booth-panel" style="padding-bottom:8px; align-self: start;">
            <div class="booth-panel-title" style="margin-bottom: 12px;">
                <i class="fa-solid fa-list"></i> Danh sách gian hàng
            </div>
            <div class="booth-list" id="booth-list">
                <!-- Injected by JS -->
            </div>
        </div>

        <!-- CENTER: Booth Form + Audio + Script -->
        <div style="display:flex; flex-direction:column; gap:20px;">

            <!-- Booth Details Form -->
            <div class="glass-card booth-panel">
                <div class="booth-panel-title">
                    <i class="fa-solid fa-pen-ruler"></i> Chi tiết gian hàng
                </div>

                <div class="grid-2 mb-4">
                    <div>
                        <label class="form-label">Tên gian hàng</label>
                        <input type="text" id="booth-name" class="form-input"
                               placeholder="Nhập tên gian hàng">
                    </div>
                    <div>
                        <label class="form-label">Công ty</label>
                        <input type="text" id="booth-company" class="form-input"
                               placeholder="Tên công ty">
                    </div>
                </div>

                <div class="grid-2 mb-4">
                    <div>
                        <label class="form-label">Danh mục</label>
                        <select id="booth-category" class="form-input form-select">
                            <option value="Technology">Công nghệ</option>
                            <option value="Food & Beverage">Thực phẩm & Đồ uống</option>
                            <option value="Fashion">Thời trang</option>
                            <option value="Health & Wellness">Sức khỏe & Thể chất</option>
                            <option value="Education">Giáo dục</option>
                            <option value="Art & Culture">Nghệ thuật & Văn hóa</option>
                            <option value="Automotive">Ô tô</option>
                            <option value="Other">Khác</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Gói dịch vụ</label>
                        <select id="booth-tier" class="form-input form-select">
                            <option value="Basic">Đơn giản</option>
                            <option value="Gold">Vàng</option>
                            <option value="Diamond">Kim cương</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Audio Editor -->
            <div class="glass-card booth-panel">
                <div class="flex-between mb-4">
                    <div class="booth-panel-title" style="margin-bottom:0;">
                        <i class="fa-solid fa-headphones-simple"></i> Thuyết minh sản phẩm
                    </div>
                    <span id="audio-status"
                          style="font-size:11px; color:var(--text-dim); background:rgba(255,255,255,0.04); padding:4px 10px; border-radius:6px;">
                        Không có file
                    </span>
                </div>

                <div class="audio-zone">
                    <!-- Upload Overlay -->
                    <div id="audio-upload-overlay" class="audio-upload-overlay">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <p style="font-size:13px; font-weight:500; color:var(--text-muted);">Nhấn hoặc kéo thả file âm thanh vào đây</p>
                        <p style="font-size:11px; color:var(--text-dim); margin-top:4px;">
                            MP3, WAV,
                            OGG (Tối đa 15MB)
                        </p>
                        <input type="file" id="audio-input" accept="audio/*" class="hidden">
                    </div>

                    <!-- Waveform -->
                    <div id="waveform" style="width:100%; height:80px; margin-bottom:12px;"></div>

                    <!-- Controls -->
                    <div class="audio-controls">
                        <div class="audio-playback">
                            <button id="btn-play" class="btn-play-circle" disabled>
                                <i class="fa-solid fa-play"></i>
                            </button>
                            <button id="btn-stop" class="btn-icon" disabled
                                    style="border-radius:50%; width:36px; height:36px;">
                                <i class="fa-solid fa-stop"></i>
                            </button>
                            <div class="volume-group">
                                <i class="fa-solid fa-volume-low"></i>
                                <input type="range" id="volume-slider" min="0" max="1" step="0.01"
                                       value="1">
                            </div>
                        </div>
                        <div class="time-display">
                            <span id="time-current">0:00</span> / <span id="time-total">0:00</span>
                        </div>
                    </div>
                </div>

                <button id="btn-clear-audio" class="btn-danger-ghost hidden mt-2">
                    <i class="fa-solid fa-trash-can"></i> Xóa file
                </button>
            </div>

            <!-- Script Editor -->
            <div class="glass-card booth-panel" style="position:relative; overflow:hidden;">
                <div style="position:absolute; top:-30px; right:-30px; width:100px; height:100px; background:radial-gradient(circle, rgba(34,197,94,0.08) 0%, transparent 70%); pointer-events:none; border-radius:50%;">
                </div>

                <div class="flex-between mb-4" style="position:relative; z-index:2;">
                    <div class="booth-panel-title" style="margin-bottom:0;">
                        <i class="fa-solid fa-pen-nib"></i>
                        <span id="script-title">Lời thoại (EN)</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <select id="lang-select" class="form-input form-select"
                                style="width:auto; padding:6px 32px 6px 10px; font-size:12px;">
                            <option value="VI">Tiếng Việt (VI)</option>
                            <option value="EN" selected>Tiếng Anh (EN)</option>
                            <option value="JA">Tiếng Nhật (JA)</option>
                            <option value="FR">Tiếng Pháp (FR)</option>
                            <option value="KO">Tiếng Hàn (KO)</option>
                            <option value="ZH">Tiếng Trung (ZH)</option>
                        </select>
                        <button id="btn-ai-optimize" class="btn-ai pulse-glow">
                            <i class="fa-solid fa-wand-magic-sparkles ai-icon"></i>
                            <span class="ai-text">Tối ưu bằng AI</span>
                        </button>
                    </div>
                </div>

                <div style="position:relative;">
                    <!-- AI Loading Overlay -->
                    <div id="ai-loading-overlay" class="ai-loading-overlay hidden">
                        <div class="ai-dots">
                            <span></span><span></span><span></span>
                        </div>
                        <p style="font-size:13px; font-weight:600; background:linear-gradient(90deg, var(--emerald), var(--forest-400)); background-clip:text; -webkit-background-clip:text; -webkit-text-fill-color:transparent;">
                            Emergent AI đang tối ưu
                        </p>
                    </div>

                    <textarea id="booth-script" class="form-input" rows="8"
                              style="min-height:160px;"
                              placeholder="Viết kịch bản thuyết minh sản phẩm cho gian hàng này..."></textarea>
                </div>

                <div class="flex-between mt-2" style="position:relative; z-index:2;">
                    <span id="word-count" style="font-size:11px; color:var(--text-dim);">
                        0
                        từ
                    </span>
                    <span id="last-saved-time" style="font-size:11px; color:var(--text-dim);">
                        Chưa
                        được lưu
                    </span>
                </div>
            </div>
        </div>

        <!-- RIGHT: Map & Geofencing -->
        <div class="glass-card booth-panel" style="position:relative;">
            <div class="booth-panel-title">
                <i class="fa-solid fa-satellite-dish"></i> Phạm vi
            </div>

            <!-- Map Container -->
            <div id="map"
                 style="width:100%; height:220px; margin-bottom:20px; background:var(--bg-deep); border-radius:10px;">
            </div>

            <!-- Lat/Lng -->
            <div class="grid-2 mb-4">
                <div>
                    <label class="form-label">Vĩ độ</label>
                    <input type="number" step="0.000001" id="input-lat" value="10.7680"
                           class="form-input mono">
                </div>
                <div>
                    <label class="form-label">Kinh độ</label>
                    <input type="number" step="0.000001" id="input-lng" value="106.7050"
                           class="form-input mono">
                </div>
            </div>

            <!-- Radius Slider -->
            <div style="background:rgba(0,0,0,0.15); border-radius:10px; padding:14px; border:1px solid var(--border);">
                <div class="flex-between mb-2">
                    <label class="form-label" style="margin-bottom:0;">
                        <i class="fa-solid fa-bullseye text-accent"
                           style="margin-right:6px;"></i>Điều chỉnh bán kính
                    </label>
                    <span id="radius-val"
                          style="font-size:13px; font-weight:700; color:var(--emerald); background:rgba(34,197,94,0.1); padding:2px 10px; border-radius:6px;">30m</span>
                </div>
                <input type="range" id="radius-slider" min="10" max="50" value="30">
                <div class="flex-between mt-2"
                     style="font-size:10px; color:var(--text-dim); font-family:monospace;">
                    <span>10m</span>
                    <span>50m</span>
                </div>
            </div>
        </div>
    </div>
</div>
