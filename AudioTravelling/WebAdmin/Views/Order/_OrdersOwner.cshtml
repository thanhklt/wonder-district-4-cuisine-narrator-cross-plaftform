<div id="view-orders-owner" class="view-section">
    <div class="flex-between mb-4">
        <div>
            <h3 class="section-title">Quản lý Đơn hàng</h3>
            <p class="section-subtitle">Theo dõi chi tiết các đơn hàng và trạng thái thanh toán</p>
        </div>
        <div class="booth-search-wrapper">
            <div class="booth-search-box">
                <i class="fa-solid fa-magnifying-glass booth-search-icon"></i>
                <input type="text" id="orders-owner-search" class="booth-search-input"
                       placeholder="Tìm kiếm mã đơn hàng..." autocomplete="off">
            </div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px;">
        
        <div class="glass-card" style="padding:24px; overflow-x:auto; align-self: start;">
            <div class="flex-between mb-4">
                <h3 style="font-size:16px; font-weight:700;">
                    <i class="fa-solid fa-list-ul text-accent" style="margin-right:8px;"></i>Danh sách đơn hàng
                </h3>
                <span id="orders-owner-count" style="font-size:12px; color:var(--text-muted);">0 đơn</span>
            </div>
            
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày</th>
                    </tr>
                </thead>
                <tbody id="orders-owner-body">
                </tbody>
            </table>
        </div>

        <div class="glass-card" style="padding:24px; align-self: start;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-file-invoice-dollar text-accent" style="margin-right:8px;"></i>Chi tiết đơn hàng
            </h3>
            
            <div id="orders-owner-details">
                <p style="text-align:center; color:var(--text-dim); padding:40px 0; font-style:italic;">
                    Vui lòng chọn một đơn hàng bên danh sách để xem chi tiết.
                </p>
            </div>
        </div>
    </div>
</div>