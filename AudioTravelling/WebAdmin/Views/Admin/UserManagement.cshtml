@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý User";
}

<div class="view-section active">
    <div class="section-header">
        <div>
            <h1 class="section-title">Quản lý User</h1>
            <p class="section-subtitle">Quản lý tất cả người dùng trong hệ thống</p>
        </div>
        <button class="btn-primary" onclick="openModal('modal-create-user')">
            <i class="fa-solid fa-user-plus"></i> Tạo User mới
        </button>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="search-input-wrapper">
            <i class="fa-solid fa-search"></i>
            <input type="text" class="search-input" placeholder="Tìm kiếm theo tên hoặc email...">
        </div>
        <select class="filter-select">
            <option value="">Tất cả vai trò</option>
            <option value="Admin">Admin</option>
            <option value="Owner">Owner</option>
            <option value="User">User</option>
        </select>
        <select class="filter-select">
            <option value="">Tất cả trạng thái</option>
            <option value="active">Hoạt động</option>
            <option value="locked">Đã khóa</option>
        </select>
    </div>

    <!-- User Table -->
    <div class="data-table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th> </th>
                    <th>User ID</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><img src="https://i.pravatar.cc/150?img=11" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--forest-600);"></td>
                    <td class="mono">#U001</td>
                    <td><strong>Nguyễn Văn Admin</strong></td>
                    <td>admin@audiotravelling.vn</td>
                    <td><span class="status-badge approved">Admin</span></td>
                    <td><span class="status-badge active"><i class="fa-solid fa-circle"></i> Hoạt động</span></td>
                    <td>
                        <div class="action-btns">
                            <button class="action-btn" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>
                            <button class="action-btn" title="Sửa"><i class="fa-solid fa-pen"></i></button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><img src="https://i.pravatar.cc/150?img=5" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--forest-600);"></td>
                    <td class="mono">#U002</td>
                    <td><strong>Trần Thị Owner</strong></td>
                    <td>owner@audiotravelling.vn</td>
                    <td><span class="status-badge" style="background:rgba(59,130,246,0.12);color:#60a5fa;border:1px solid rgba(59,130,246,0.25);">Owner</span></td>
                    <td><span class="status-badge active"><i class="fa-solid fa-circle"></i> Hoạt động</span></td>
                    <td>
                        <div class="action-btns">
                            <button class="action-btn" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>
                            <button class="action-btn" title="Sửa"><i class="fa-solid fa-pen"></i></button>
                            <button class="action-btn danger" title="Khóa" onclick="confirmAction('Khóa tài khoản Trần Thị Owner?', function(){ showToast('Đã khóa tài khoản!', 'success'); });"><i class="fa-solid fa-lock"></i></button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><img src="https://i.pravatar.cc/150?img=8" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--forest-600);"></td>
                    <td class="mono">#U003</td>
                    <td><strong>Lê Minh Quán</strong></td>
                    <td>owner2@audiotravelling.vn</td>
                    <td><span class="status-badge" style="background:rgba(59,130,246,0.12);color:#60a5fa;border:1px solid rgba(59,130,246,0.25);">Owner</span></td>
                    <td><span class="status-badge active"><i class="fa-solid fa-circle"></i> Hoạt động</span></td>
                    <td>
                        <div class="action-btns">
                            <button class="action-btn" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>
                            <button class="action-btn" title="Sửa"><i class="fa-solid fa-pen"></i></button>
                            <button class="action-btn danger" title="Khóa"><i class="fa-solid fa-lock"></i></button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><img src="https://i.pravatar.cc/150?img=3" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--forest-600);"></td>
                    <td class="mono">#U004</td>
                    <td><strong>Nguyễn Hoàng Nam</strong></td>
                    <td>nam@gmail.com</td>
                    <td><span class="status-badge" style="background:rgba(107,114,128,0.12);color:#9ca3af;border:1px solid rgba(107,114,128,0.25);">User</span></td>
                    <td><span class="status-badge active"><i class="fa-solid fa-circle"></i> Hoạt động</span></td>
                    <td>
                        <div class="action-btns">
                            <button class="action-btn" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>
                            <button class="action-btn" title="Sửa"><i class="fa-solid fa-pen"></i></button>
                            <button class="action-btn danger" title="Khóa"><i class="fa-solid fa-lock"></i></button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><img src="https://i.pravatar.cc/150?img=12" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--forest-600);"></td>
                    <td class="mono">#U005</td>
                    <td><strong>Phạm Văn Hoàng</strong></td>
                    <td>hoang@gmail.com</td>
                    <td><span class="status-badge" style="background:rgba(107,114,128,0.12);color:#9ca3af;border:1px solid rgba(107,114,128,0.25);">User</span></td>
                    <td><span class="status-badge active"><i class="fa-solid fa-circle"></i> Hoạt động</span></td>
                    <td>
                        <div class="action-btns">
                            <button class="action-btn" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>
                            <button class="action-btn" title="Sửa"><i class="fa-solid fa-pen"></i></button>
                            <button class="action-btn danger" title="Khóa"><i class="fa-solid fa-lock"></i></button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td><img src="https://i.pravatar.cc/150?img=9" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid var(--forest-600);"></td>
                    <td class="mono">#U006</td>
                    <td><strong>Nguyễn Thị Lan</strong></td>
                    <td>lan@gmail.com</td>
                    <td><span class="status-badge" style="background:rgba(107,114,128,0.12);color:#9ca3af;border:1px solid rgba(107,114,128,0.25);">User</span></td>
                    <td><span class="status-badge inactive"><i class="fa-solid fa-circle"></i> Đã khóa</span></td>
                    <td>
                        <div class="action-btns">
                            <button class="action-btn" title="Chi tiết"><i class="fa-solid fa-eye"></i></button>
                            <button class="action-btn" title="Sửa"><i class="fa-solid fa-pen"></i></button>
                            <button class="action-btn approve" title="Mở khóa" onclick="confirmAction('Mở khóa tài khoản Nguyễn Thị Lan?', function(){ showToast('Đã mở khóa!', 'success'); });"><i class="fa-solid fa-unlock"></i></button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="pagination-bar">
        <span class="pagination-info">Hiển thị 1-6 trong tổng số 8 user</span>
        <div class="pagination-buttons">
            <button class="pagination-btn" disabled><i class="fa-solid fa-chevron-left"></i></button>
            <button class="pagination-btn active">1</button>
            <button class="pagination-btn">2</button>
            <button class="pagination-btn"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </div>

    <!-- Create User Modal -->
    <div class="modal-overlay" id="modal-create-user">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title"><i class="fa-solid fa-user-plus" style="color:var(--emerald);"></i> Tạo User mới</h3>
                <button class="modal-close" onclick="closeModal('modal-create-user')"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="grid-2">
                    <div class="form-group">
                        <label>Họ</label>
                        <input type="text" class="form-input" placeholder="Nguyễn">
                    </div>
                    <div class="form-group">
                        <label>Tên</label>
                        <input type="text" class="form-input" placeholder="Văn A">
                    </div>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" class="form-input" placeholder="email@example.com">
                </div>
                <div class="form-group">
                    <label>Mật khẩu</label>
                    <input type="password" class="form-input" placeholder="Ít nhất 6 ký tự">
                </div>
                <div class="form-group">
                    <label>Role</label>
                    <select class="form-input form-select">
                        <option value="Owner">Owner</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Số điện thoại</label>
                    <input type="tel" class="form-input" placeholder="+84 xxx xxx xxx">
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" onclick="closeModal('modal-create-user')">Hủy</button>
                <button class="btn-primary" onclick="closeModal('modal-create-user'); showToast('Tạo user thành công!', 'success');">
                    <i class="fa-solid fa-save"></i> Lưu
                </button>
            </div>
        </div>
    </div>
</div>
