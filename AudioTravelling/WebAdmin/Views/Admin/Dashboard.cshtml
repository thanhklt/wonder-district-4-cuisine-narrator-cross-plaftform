@model AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tổng quan";
}

<div class="view-section active">
    <!-- Page Header -->
    <div class="section-header">
        <div>
            <h1 class="section-title">Tổng quan hệ thống</h1>
            <p class="section-subtitle">Xin chào, @User.Identity?.Name! Đây là tổng quan hoạt động hôm nay.</p>
        </div>
    </div>

    <!-- ══════════════ STAT CARDS ══════════════ -->
    <div class="stats-grid">
        <!-- Tổng POI -->
        <div class="glass-card stat-card">
            <div class="stat-icon blue">
                <i class="fa-solid fa-map-marker-alt"></i>
            </div>
            <div>
                <p class="stat-label">Số lượng POI</p>
                <p class="stat-value">@Model.TotalPoi</p>
            </div>
        </div>

        <!-- POI Pending -->
        <div class="glass-card stat-card">
            <div class="stat-icon amber">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div>
                <p class="stat-label">Chờ duyệt</p>
                <p class="stat-value">@Model.PendingPoi</p>
            </div>
        </div>

        <!-- POI Approved -->
        <div class="glass-card stat-card">
            <div class="stat-icon green">
                <i class="fa-solid fa-check-circle"></i>
            </div>
            <div>
                <p class="stat-label">Đã duyệt</p>
                <p class="stat-value">@Model.ApprovedPoi</p>
            </div>
        </div>

        <!-- POI Rejected -->
        <div class="glass-card stat-card">
            <div class="stat-icon red">
                <i class="fa-solid fa-times-circle"></i>
            </div>
            <div>
                <p class="stat-label">Từ chối</p>
                <p class="stat-value">@Model.RejectedPoi</p>
            </div>
        </div>

        <!-- POI Active -->
        <div class="glass-card stat-card">
            <div class="stat-icon green">
                <i class="fa-solid fa-signal"></i>
            </div>
            <div>
                <p class="stat-label">Đang hoạt động</p>
                <p class="stat-value">@Model.ActivePoi</p>
            </div>
        </div>

        <!-- Tổng User -->
        <div class="glass-card stat-card">
            <div class="stat-icon purple">
                <i class="fa-solid fa-users"></i>
            </div>
            <div>
                <p class="stat-label">Tổng User</p>
                <p class="stat-value">@Model.TotalUsers</p>
            </div>
        </div>
    </div>

    <!-- ══════════════ CHARTS ROW ══════════════ -->
    <div class="dashboard-row">
        <!-- POI theo trạng thái (Doughnut) -->
        <div class="glass-card dashboard-card">
            <div class="dashboard-card-header">
                <h3 class="dashboard-card-title">
                    <i class="fa-solid fa-chart-pie"></i> POI theo trạng thái
                </h3>
            </div>
            <div class="chart-container">
                <canvas id="poiStatusChart"></canvas>
            </div>
        </div>

        <!-- POI theo Package (Bar) -->
        <div class="glass-card dashboard-card">
            <div class="dashboard-card-header">
                <h3 class="dashboard-card-title">
                    <i class="fa-solid fa-chart-bar"></i> POI theo Package
                </h3>
            </div>
            <div class="chart-container">
                <canvas id="poiPackageChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── POI Status Doughnut Chart ──
        const statusCtx = document.getElementById('poiStatusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Chờ duyệt', 'Đã duyệt', 'Từ chối'],
                datasets: [{
                    data: [@Model.PendingPoi, @Model.ApprovedPoi, @Model.RejectedPoi],
                    backgroundColor: [
                        'rgba(245, 158, 11, 0.8)',
                        'rgba(34, 197, 94, 0.8)',
                        'rgba(239, 68, 68, 0.8)'
                    ],
                    borderColor: [
                        'rgba(245, 158, 11, 1)',
                        'rgba(34, 197, 94, 1)',
                        'rgba(239, 68, 68, 1)'
                    ],
                    borderWidth: 1,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: '#111827',
                            padding: 16,
                            font: { family: 'Inter', size: 12, weight: 600 }
                        }
                    }
                }
            }
        });

        // ── POI Package Bar Chart ──
        const packageCtx = document.getElementById('poiPackageChart').getContext('2d');
        new Chart(packageCtx, {
            type: 'bar',
            data: {
                labels: ['Cơ bản', 'Nâng cao', 'Chuyên nghiệp'],
                datasets: [{
                    label: 'Số POI',
                    data: [5, 4, 3],
                    backgroundColor: [
                        'rgba(148, 163, 184, 0.6)',
                        'rgba(251, 191, 36, 0.6)',
                        'rgba(167, 139, 250, 0.6)'
                    ],
                    borderColor: [
                        'rgba(148, 163, 184, 1)',
                        'rgba(251, 191, 36, 1)',
                        'rgba(167, 139, 250, 1)'
                    ],
                    borderWidth: 1,
                    borderRadius: 8,
                    barThickness: 48
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            color: '#4b5563',
                            font: { family: 'Inter', size: 11 },
                            stepSize: 1
                        },
                        grid: {
                            color: 'rgba(34, 197, 94, 0.06)'
                        }
                    },
                    x: {
                        ticks: {
                            color: '#111827',
                            font: { family: 'Inter', size: 12, weight: 600 }
                        },
                        grid: { display: false }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>
}
