<!DOCTYPE html>
<html lang="vn" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audio Travelling — Portal</title>
    <meta name="description"
          content="Audio Travelling Portal - Quản lý POI, mã QR và thống kê truy cập hệ thống">

    <!-- Design System - Modular CSS -->
    <link rel="stylesheet" href="~/css/base.css">
    <link rel="stylesheet" href="~/css/layout.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
    <link rel="stylesheet" href="~/css/auth.css">
    <link rel="stylesheet" href="~/css/misc.css">
    <link rel="stylesheet" href="~/css/theme-light.css">
    <link rel="stylesheet" href="~/css/admin.css">
    <link rel="stylesheet" href="~/css/owner.css">

    <!-- FontAwesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <!-- Leaflet Heat Plugin (for heatmap) -->
    <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>

    <!-- Toastify -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
</head>

<body>

    <!-- ═══════════════════════════════════════
         AUTH SCREEN (Login)
         ═══════════════════════════════════════ -->
    <div id="auth-screen" class="login-screen">
        <!-- Floating background image -->
        <img class="auth-bg" src="~/images/am_thuc.jpg" alt="" aria-hidden="true">
        <div class="auth-particles">
            <div class="auth-particle"></div>
            <div class="auth-particle"></div>
            <div class="auth-particle"></div>
            <div class="auth-particle"></div>
            <div class="auth-particle"></div>
        </div>

        <div class="auth-card glass-strong">

            <!-- Logo & Branding -->
            <div class="login-logo">
                <img src="~/images/logo_cty.jpg" alt="Logo Công ty" style="width: 80px; height: auto;">
            </div>
            <h1 class="login-title">Quản lý gian hàng</h1>
            <p class="login-subtitle">Phố ẩm thực Khánh Hội</p>

            <!-- LOGIN FORM -->
            <form id="form-login" class="auth-form active" autocomplete="off">
                <div class="auth-field">
                    <label class="auth-label" for="login-email">
                        <i class="fa-solid fa-envelope"></i> Địa chỉ Email
                    </label>
                    <input type="email" id="login-email" class="auth-input" placeholder="admin@audiotravelling.com"
                           required>
                </div>

                <div class="auth-field">
                    <label class="auth-label" for="login-password">
                        <i class="fa-solid fa-lock"></i> Mật khẩu
                    </label>
                    <div class="auth-password-wrapper">
                        <input type="password" id="login-password" class="auth-input" placeholder="••••••••" required
                               minlength="6">
                        <button type="button" class="auth-toggle-pw" data-target="login-password" tabindex="-1">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="auth-row">
                    <label class="auth-checkbox-label">
                        <input type="checkbox" id="login-remember" class="auth-checkbox">
                        <span class="auth-checkmark"></span>
                        Ghi nhớ
                    </label>
                    <a href="#" class="auth-link" onclick="event.preventDefault();">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="auth-submit-btn" id="btn-login">
                    <span class="auth-btn-text">Đăng nhập</span>
                    <i class="fa-solid fa-arrow-right auth-btn-arrow"></i>
                </button>

                <p class="auth-error hidden" id="login-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span id="login-error-text">Sai thông tin đăng nhập</span>
                </p>
            </form>
        </div>
    </div>

    <!-- ═══════════════════════════════════════
         MAIN DASHBOARD APP
         ═══════════════════════════════════════ -->
    <div id="dashboard-app" style="display:none; height:100vh;">

        <div style="display:flex; height:100vh; overflow:hidden;">

            <!-- ── SIDEBAR ── -->
            <aside class="sidebar" id="app-sidebar">
                <div class="sidebar-brand">
                    <div class="sidebar-brand-icon">
                        <i class="fa-solid fa-headphones"></i>
                    </div>
                    <div class="sidebar-brand-text">
                        Du Hí <span>Đó Đây</span>
                        <small>Phố ẩm thực Khánh Hội</small>
                    </div>
                </div>

                <nav class="sidebar-nav" id="sidebar-nav">
                    <!-- Dynamically rendered by JS based on role -->
                </nav>

                <div class="sidebar-footer">
                    <div class="sidebar-user">
                        <img id="sidebar-avatar" src="https://i.pravatar.cc/150?img=11" alt="User"
                             class="sidebar-avatar">
                        <div class="sidebar-user-info">
                            <p id="sidebar-name" class="sidebar-user-name">User</p>
                            <button id="btn-logout" class="btn-signout">
                                <i class="fa-solid fa-arrow-right-from-bracket"></i> Đăng xuất
                            </button>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- ── MAIN CONTENT ── -->
            <main class="main-area">
                <!-- Top Header Bar -->
                <header class="top-header">
                    <h2 id="header-title">Tổng quan</h2>
                    <div style="display:flex; align-items:center; gap:12px;">
                    </div>
                </header>

                <!-- Scrollable Content -->
                <div class="content-wrapper">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <!-- ═══════════════════════════════════════
         SCRIPTS — Loaded in dependency order
         ═══════════════════════════════════════ -->

    <!-- 1. Config -->
    <script src="~/js/config/roles.js"></script>
    <script src="~/js/config/routes.js"></script>

    <!-- 2. Core -->
    <script src="~/js/core/storage.js"></script>
    <script src="~/js/core/apiClient.js"></script>
    <script src="~/js/core/ui.js"></script>
    <script src="~/js/core/auth.js"></script>
    <script src="~/js/core/roleGuard.js"></script>
    <script src="~/js/core/router.js"></script>

    <!-- 3. Mocks -->
    <script src="~/js/mocks/mockData.js"></script>

    <!-- 4. Services -->
    <script src="~/js/services/poiService.js"></script>
    <script src="~/js/services/qrService.js"></script>
    <script src="~/js/services/accessStatsService.js"></script>
    <script src="~/js/services/heatmapService.js"></script>

    <!-- 5. Utils -->
    <script src="~/js/utils/formatters.js"></script>
    <script src="~/js/utils/validators.js"></script>

    <!-- 6. Admin Modules -->
    <script src="~/js/modules/admin/adminDashboard.js"></script>
    <script src="~/js/modules/admin/qrManagement.js"></script>
    <script src="~/js/modules/admin/poiApproval.js"></script>

    <script src="~/js/modules/admin/heatmap.js"></script>

    <!-- 7. Owner Modules -->
    <script src="~/js/modules/owner/ownerDashboard.js"></script>
    <script src="~/js/modules/owner/myPois.js"></script>
    <script src="~/js/modules/owner/createPoi.js"></script>
    <script src="~/js/modules/owner/poiStatus.js"></script>

    <!-- 8. App Bootstrap (LAST) -->
    <script src="~/js/app.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
