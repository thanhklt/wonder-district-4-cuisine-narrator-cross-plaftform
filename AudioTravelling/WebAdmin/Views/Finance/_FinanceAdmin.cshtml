<div id="view-finance" class="view-section">
    <div class="section-header">
        <div>
            <h3 class="section-title">Quản lý Đơn hàng & Đối soát</h3>
            <p class="section-subtitle">Theo dõi toàn bộ đơn hàng trên hệ thống và đối soát hoa hồng.</p>
        </div>
        <div class="booth-search-wrapper">
            <div class="booth-search-box">
                <i class="fa-solid fa-magnifying-glass booth-search-icon"></i>
                <input type="text" id="finance-admin-search" class="booth-search-input"
                       placeholder="Tìm kiếm mã đơn hoặc tên gian hàng..." autocomplete="off">
                <button type="button" id="finance-admin-search-clear" class="booth-search-clear hidden">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px;">
        
        <div class="glass-card" style="padding:24px; overflow-x:auto; align-self: start;">
            <div class="flex-between mb-4">
                <h3 style="font-size:16px; font-weight:700;">
                    <i class="fa-solid fa-receipt text-accent" style="margin-right:8px;"></i>Tất cả đơn hàng
                </h3>
                <span id="finance-admin-order-count" style="font-size:12px; color:var(--text-muted);">0 đơn</span>
            </div>
            
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Gian hàng</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Ngày</th>
                    </tr>
                </thead>
                <tbody id="finance-admin-orders-body">
                </tbody>
            </table>
        </div>

        <div class="glass-card" style="padding:24px; align-self: start;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-circle-info text-accent" style="margin-right:8px;"></i>Chi tiết đơn hàng
            </h3>
            
            <div id="finance-admin-order-details">
                <p style="text-align:center; color:var(--text-dim); padding:40px 0; font-style:italic;">
                    Vui lòng chọn một đơn hàng bên danh sách để xem chi tiết.
                </p>
            </div>
        </div>
    </div>
</div>