<!-- ════════════════════════════════════
     SCREEN 6: ADMIN PROFILE & SETTINGS
     ════════════════════════════════════ -->
<div id="view-settings" class="view-section">

    <div class="section-header">
        <div>
            <h3 class="section-title">Thông tin cá nhân và cài đặt</h3>
            <p class="section-subtitle">Quản lý thông tin cá nhân và cấu hình hệ thống</p>
        </div>
    </div>

    <div class="settings-grid">

        <!-- Profile Card -->
        <div class="glass-card booth-panel">
            <div class="flex-between mb-6"
                 style="border-bottom:1px solid var(--border); padding-bottom:16px;">
                <div class="booth-panel-title" style="margin-bottom:0;">
                    <i class="fa-solid fa-user-shield"></i> Thông tin cá nhân
                </div>
                <button id="btn-edit-profile" class="btn-ghost" style="font-size:12px;">
                    <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa
                </button>
                <div id="profile-edit-actions" class="hidden"
                     style="display:flex; align-items:center; gap:10px;">
                    <button id="btn-cancel-profile" class="btn-ghost"
                            style="font-size:12px;">
                        Hủy
                    </button>
                    <button id="btn-save-profile" class="btn-primary" style="font-size:12px;">
                        <i class="fa-solid fa-floppy-disk"></i> Lưu
                    </button>
                </div>
            </div>

            <!-- Avatar + Name -->
            <div style="display:flex; align-items:center; gap:20px; margin-bottom:24px;">
                <div class="profile-avatar-wrapper">
                    <img id="profile-avatar-preview" src="https://i.pravatar.cc/150?img=11"
                         class="profile-avatar" alt="Admin Avatar">
                    <input type="file" id="profile-avatar-input" accept="image/*" class="hidden">
                    <div id="profile-avatar-overlay" class="profile-avatar-overlay">
                        <i class="fa-solid fa-camera"></i>
                    </div>
                </div>
                <div style="flex:1;">
                    <label class="form-label">Họ và tên</label>
                    <input type="text" id="set-name" value="Admin"
                           class="form-input profile-editable" disabled>
                </div>
            </div>

            <!-- Email (always read-only) -->
            <div class="mb-4">
                <label class="form-label">Email (Emergent Login)</label>
                <input type="email" id="set-email" value="admin@audiotravelling.com"
                       class="form-input" disabled style="opacity:0.5; cursor:not-allowed;">
            </div>

            <!-- Phone -->
            <div class="mb-4">
                <label class="form-label">Số điện thoại</label>
                <input type="tel" id="set-phone" value="+84 123 456 789"
                       class="form-input profile-editable" disabled>
            </div>

            <!-- Bio -->
            <div>
                <label class="form-label">Thông tin </label>
                <textarea id="set-bio" class="form-input profile-editable" rows="3"
                          disabled>Quản lý hội chợ phụ trách việc sắp xếp gian hàng, thuyết minh âm thanh và theo dõi hoa hồng cho các sự kiện của Audio Travelling.</textarea>
            </div>
        </div>

        <!-- Social Login + Tier Configuration -->
        <div style="display:flex; flex-direction:column; gap:20px;">

            <!-- Emergent Social Login Status -->
            <div class="glass-card booth-panel">
                <div class="booth-panel-title">
                    <i class="fa-solid fa-link"></i> Đăng nhập Emergent
                </div>
                <div style="display:flex; align-items:center; gap:16px; margin-bottom:16px;">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg"
                         style="width:32px; height:32px;" alt="Google">
                    <div style="flex:1;">
                        <p style="font-weight:600; font-size:14px;">Tài khoản Google</p>
                        <p style="font-size:12px; color:var(--text-muted);">
                            admin@audiotravelling.com
                        </p>
                    </div>
                    <div id="social-status" class="social-login-badge connected">
                        <i class="fa-solid fa-circle-check"></i> Đã kết nối
                    </div>
                </div>
                <p style="font-size:12px; color:var(--text-dim); line-height:1.6;">
                    Tài khoản Google của bạn được liên kết thông qua nền tảng Emergent Social Login. Quá trình xác thực được xử lý bảo mật qua OAuth 2.0.
                </p>
            </div>

            <!-- Tier Commission Configuration -->
            <div class="glass-card booth-panel">
                <div class="booth-panel-title">
                    <i class="fa-solid fa-sliders"></i> Tỷ lệ hoa hồng theo gói
                </div>

                <!-- Basic Tier -->
                <div class="tier-config-card">
                    <div class="tier-config-header">
                        <span class="tier-badge tier-basic">
                            <i class="fa-solid fa-circle"
                               style="font-size:6px;"></i> GÓI CƠ BẢN
                        </span>
                    </div>
                    <div class="tier-config-inputs">
                        <div>
                            <label class="form-label">Tỷ lệ (R<sub>c</sub>)</label>
                            <input type="number" step="0.01" id="rc-basic" value="0.10"
                                   class="form-input mono" min="0" max="1">
                        </div>
                        <div>
                            <label class="form-label">Phí (F) VNĐ</label>
                            <input type="number" step="0.01" id="fee-basic" value="35000"
                                   class="form-input mono" min="0">
                        </div>
                    </div>
                </div>

                <!-- Gold Tier -->
                <div class="tier-config-card">
                    <div class="tier-config-header">
                        <span class="tier-badge tier-gold">
                            <i class="fa-solid fa-circle"
                               style="font-size:6px;"></i> GÓI VÀNG
                        </span>
                    </div>
                    <div class="tier-config-inputs">
                        <div>
                            <label class="form-label">Tỷ lệ (R<sub>c</sub>)</label>
                            <input type="number" step="0.01" id="rc-gold" value="0.08"
                                   class="form-input mono" min="0" max="1">
                        </div>
                        <div>
                            <label class="form-label">Phí (F) VNĐ</label>
                            <input type="number" step="0.01" id="fee-gold" value="25000"
                                   class="form-input mono" min="0">
                        </div>
                    </div>
                </div>

                <!-- Diamond Tier -->
                <div class="tier-config-card">
                    <div class="tier-config-header">
                        <span class="tier-badge tier-diamond">
                            <i class="fa-solid fa-diamond"
                               style="font-size:6px;"></i> GÓI KIM CƯƠNG
                        </span>
                    </div>
                    <div class="tier-config-inputs">
                        <div>
                            <label class="form-label">Tỷ lệ (R<sub>c</sub>)</label>
                            <input type="number" step="0.01" id="rc-diamond" value="0.05"
                                   class="form-input mono" min="0" max="1">
                        </div>
                        <div>
                            <label class="form-label">Phí (F) VNĐ</label>
                            <input type="number" step="0.01" id="fee-diamond" value="15000"
                                   class="form-input mono" min="0">
                        </div>
                    </div>
                </div>

                <button id="btn-save-settings" class="btn-primary btn-ripple"
                        style="width:100%; justify-content:center; margin-top:8px;">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu cấu hình
                </button>
            </div>
        </div>
    </div>
</div>
