<!-- ── REGISTER FORM ── -->
        <form id="form-register" class="auth-form" autocomplete="off">
            <div class="auth-field">
                <label class="auth-label" for="reg-name">
                    <i class="fa-solid fa-user"></i> Họ tên
                </label>
                <input type="text" id="reg-name" class="auth-input" placeholder="Nguyễn Văn A" required>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="reg-email">
                    <i class="fa-solid fa-envelope"></i> Địa chỉ Email
                </label>
                <input type="email" id="reg-email" class="auth-input" placeholder="email@company.com" required>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="reg-phone">
                    <i class="fa-solid fa-phone"></i> Số điện thoại
                </label>
                <input type="tel" id="reg-phone" class="auth-input" placeholder="+84 123 456 789">
            </div>

            <div class="auth-field">
                <label class="auth-label" for="reg-password">
                    <i class="fa-solid fa-lock"></i> Mật khẩu
                </label>
                <div class="auth-password-wrapper">
                    <input type="password" id="reg-password" class="auth-input" placeholder="Ít nhất 6 ký tự"
                        required minlength="6">
                    <button type="button" class="auth-toggle-pw" data-target="reg-password" tabindex="-1">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" for="reg-confirm">
                    <i class="fa-solid fa-shield-halved"></i> Xác nhận mật khẩu
                </label>
                <div class="auth-password-wrapper">
                    <input type="password" id="reg-confirm" class="auth-input" placeholder="Nhập lại mật khẩu"
                        required>
                    <button type="button" class="auth-toggle-pw" data-target="reg-confirm" tabindex="-1">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
            </div>

            <label class="auth-checkbox-label" style="margin-bottom:4px;">
                <input type="checkbox" id="reg-terms" class="auth-checkbox" required>
                <span class="auth-checkmark"></span>
                Tôi đồng ý với <a href="#" class="auth-link" onclick="event.preventDefault();">Điều khoản dịch
                    vụ</a>
                và <a href="#" class="auth-link" onclick="event.preventDefault();">Chính sách bảo mật</a>
            </label>

            <button type="submit" class="auth-submit-btn" id="btn-register">
                <span class="auth-btn-text">Tạo tài khoản</span>
                <i class="fa-solid fa-user-plus auth-btn-arrow"></i>
            </button>

            <p class="auth-error hidden" id="register-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span id="register-error-text">Đăng ký thất bại</span>
            </p>

            <p class="auth-success hidden" id="register-success">
                <i class="fa-solid fa-circle-check"></i>
                <span>Tạo tài khoản thành công! Đang chuyển hướng đến trang đăng nhập...</span>
            </p>
        </form>

        <p class="login-footer">Chỉ dành cho nhân viên có thẩm quyền. Được cung cấp bởi Emergent AI.</p>
