<!-- ══════════════ CREATE/EDIT POI MODAL ══════════════ -->
<div class="modal-overlay" id="modal-create-poi">
    <div class="modal-content" style="max-width:640px;">
        <div class="modal-header">
            <h3 class="modal-title"><i class="fa-solid fa-map-marker-alt" style="color:var(--emerald);"></i> Tạo POI mới</h3>
            <button class="modal-close" onclick="closeModal('modal-create-poi')"><i class="fa-solid fa-times"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Tên POI (tiếng Việt) <span style="color:#f87171;">*</span></label>
                <input type="text" class="form-input" placeholder="VD: Quán Ốc Đào" id="poi-name">
            </div>

            <div class="form-group">
                <label>Mô tả (tiếng Việt) <span style="color:#f87171;">*</span></label>
                <textarea class="form-input" rows="4" placeholder="Mô tả chi tiết về quán ăn, đặc sản, không gian..." id="poi-desc"></textarea>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label>Latitude <span style="color:#f87171;">*</span></label>
                    <input type="number" step="0.0001" class="form-input mono" placeholder="10.7578" id="poi-lat">
                </div>
                <div class="form-group">
                    <label>Longitude <span style="color:#f87171;">*</span></label>
                    <input type="number" step="0.0001" class="form-input mono" placeholder="106.6955" id="poi-lng">
                </div>
            </div>

            <div class="form-group">
                <label>Package <span style="color:#f87171;">*</span></label>
                <select class="form-input form-select" id="poi-package" onchange="updatePackageSpecs()">
                    <option value="">-- Chọn package --</option>
                    <option value="1" data-radius="15" data-priority="0">Cơ bản (Miễn phí)</option>
                    <option value="2" data-radius="30" data-priority="1">Nâng cao (200.000đ/tháng)</option>
                    <option value="3" data-radius="50" data-priority="2">Chuyên nghiệp (500.000đ/tháng)</option>
                </select>
            </div>

            <div class="grid-2">
                <div class="form-group readonly">
                    <label>Radius (m) — tự động theo package</label>
                    <input type="number" class="form-input" id="poi-radius" readonly placeholder="—">
                    <p class="form-hint">Giá trị tự động theo package đã chọn</p>
                </div>
                <div class="form-group readonly">
                    <label>Priority — tự động theo package</label>
                    <input type="number" class="form-input" id="poi-priority" readonly placeholder="—">
                    <p class="form-hint">Giá trị tự động theo package đã chọn</p>
                </div>
            </div>

            <div class="form-group">
                <label>Ảnh POI (1-3 ảnh) <span style="color:#f87171;">*</span></label>
                <div style="border:2px dashed var(--border-glass);border-radius:12px;padding:24px;text-align:center;cursor:pointer;" onclick="document.getElementById('poi-images').click();">
                    <i class="fa-solid fa-cloud-arrow-up" style="font-size:24px;color:var(--text-dim);margin-bottom:8px;display:block;"></i>
                    <p style="font-size:13px;color:var(--text-muted);">Kéo thả hoặc click để chọn ảnh</p>
                    <p style="font-size:11px;color:var(--text-dim);margin-top:4px;">Tối thiểu 1 ảnh, tối đa 3 ảnh. Ảnh đầu tiên là cover.</p>
                </div>
                <input type="file" id="poi-images" multiple accept="image/*" style="display:none;" onchange="previewImages(this)">
                <div class="image-preview-grid mt-2" id="image-previews"></div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-ghost" onclick="closeModal('modal-create-poi')">Hủy</button>
            <button class="btn-ghost" onclick="closeModal('modal-create-poi'); showToast('Đã lưu nháp POI!', 'success');">
                <i class="fa-solid fa-save"></i> Lưu nháp
            </button>
            <button class="btn-primary" onclick="submitPoi()">
                <i class="fa-solid fa-paper-plane"></i> Gửi duyệt
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Auto-fill radius/priority based on package selection ──
        function updatePackageSpecs() {
            const select = document.getElementById('poi-package');
            const option = select.options[select.selectedIndex];
            const radius = option.getAttribute('data-radius') || '';
            const priority = option.getAttribute('data-priority') || '';
            document.getElementById('poi-radius').value = radius;
            document.getElementById('poi-priority').value = priority;
        }

        // ── Image preview ──
        function previewImages(input) {
            const container = document.getElementById('image-previews');
            container.innerHTML = '';

            if (input.files.length > 3) {
                showToast('Tối đa 3 ảnh!', 'error');
                input.value = '';
                return;
            }

            Array.from(input.files).forEach((file, idx) => {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const div = document.createElement('div');
                    div.className = 'image-preview-item';
                    div.innerHTML = `
                        <img src="${e.target.result}" alt="Preview">
                        ${idx === 0 ? '<span class="cover-badge">Cover</span>' : ''}
                        <button class="remove-btn" onclick="this.parentElement.remove()">
                            <i class="fa-solid fa-times"></i>
                        </button>
                    `;
                    container.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        }

        // ── Submit POI ──
        function submitPoi() {
            const name = document.getElementById('poi-name').value.trim();
            const desc = document.getElementById('poi-desc').value.trim();
            const lat = document.getElementById('poi-lat').value;
            const lng = document.getElementById('poi-lng').value;
            const pkg = document.getElementById('poi-package').value;

            if (!name || !desc || !lat || !lng || !pkg) {
                showToast('Vui lòng điền đầy đủ thông tin!', 'error');
                return;
            }

            closeModal('modal-create-poi');
            showToast('Đã gửi POI chờ duyệt thành công!', 'success');
        }
    </script>
}
