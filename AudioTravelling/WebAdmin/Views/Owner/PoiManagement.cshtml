                    <td>30m</td>
                    <td>1</td>
                    <td><span class="status-badge pending"><i class="fa-solid fa-circle"></i> Chờ duyệt</span></td>
                    <td><span class="status-badge inactive"><i class="fa-solid fa-circle"></i> Không hoạt động</span></td>
