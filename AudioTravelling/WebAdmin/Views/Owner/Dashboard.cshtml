@model OwnerDashboardViewModel
@{
    Layout = "_OwnerLayout";
    ViewData["Title"] = "Tổng quan";
}

<div class="view-section active">
    <!-- Page Header -->
    <div class="section-header">
        <div>
            <h1 class="section-title">Tổng quan</h1>
            <p class="section-subtitle">Xin chào, @User.Identity?.Name!</p>
        </div>
        <a href="/Owner/PoiManagement" class="btn-primary">
            <i class="fa-solid fa-plus"></i> Tạo POI mới
        </a>
    </div>

    <!-- ══════════════ STAT CARDS ══════════════ -->
    <div class="owner-stats-grid">
        <!-- Tổng POI -->
        <div class="glass-card stat-card">
            <div class="stat-icon blue">
                <i class="fa-solid fa-map-marker-alt"></i>
            </div>
            <div>
                <p class="stat-label">Số lượng gian hàng</p>
                <p class="stat-value">@Model.TotalPoi</p>
            </div>
        </div>

        <!-- Pending -->
        <div class="glass-card stat-card">
            <div class="stat-icon amber">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div>
                <p class="stat-label">Chờ duyệt</p>
                <p class="stat-value">@Model.PendingPoi</p>
            </div>
        </div>

        <!-- Approved -->
        <div class="glass-card stat-card">
            <div class="stat-icon green">
                <i class="fa-solid fa-check-circle"></i>
            </div>
            <div>
                <p class="stat-label">Đã duyệt</p>
                <p class="stat-value">@Model.ApprovedPoi</p>
            </div>
        </div>

        <!-- Rejected -->
        <div class="glass-card stat-card">
            <div class="stat-icon red">
                <i class="fa-solid fa-times-circle"></i>
            </div>
            <div>
                <p class="stat-label">Từ chối</p>
                <p class="stat-value">@Model.RejectedPoi</p>
            </div>
        </div>

        <!-- Active -->
        <div class="glass-card stat-card">
            <div class="stat-icon green">
                <i class="fa-solid fa-signal"></i>
            </div>
            <div>
                <p class="stat-label">Đang hoạt động</p>
                <p class="stat-value">@Model.ActivePoi</p>
            </div>
        </div>
    </div>

    <!-- ══════════════ POI STATUS CHART ══════════════ -->
    <div class="dashboard-row">
        <div class="glass-card dashboard-card">
            <div class="dashboard-card-header">
                <h3 class="dashboard-card-title">
                    <i class="fa-solid fa-chart-pie"></i> Thống kê POI 
                </h3>
            </div>
            <div class="chart-container">
                <canvas id="ownerPoiChart"></canvas>
            </div>
        </div>

        
    </div>
</div>

@section Scripts {
    <script>
        // ── Owner POI Status Doughnut ──
        const ctx = document.getElementById('ownerPoiChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Chờ duyệt', 'Đã duyệt', 'Từ chối'],
                datasets: [{
                    data: [@Model.PendingPoi, @Model.ApprovedPoi, @Model.RejectedPoi],
                    backgroundColor: [
                        'rgba(245, 158, 11, 0.8)',
                        'rgba(34, 197, 94, 0.8)',
                        'rgba(239, 68, 68, 0.8)'
                    ],
                    borderColor: [
                        'rgba(245, 158, 11, 1)',
                        'rgba(34, 197, 94, 1)',
                        'rgba(239, 68, 68, 1)'
                    ],
                    borderWidth: 1,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: '#111827',
                            padding: 16,
                            font: { family: 'Inter', size: 12, weight: 600 }
                        }
                    }
                }
            }
        });
    </script>
}
