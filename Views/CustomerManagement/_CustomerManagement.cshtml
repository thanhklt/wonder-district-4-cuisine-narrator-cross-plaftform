<div id="view-customers" class="view-section">
    <div class="section-header">
        <div>
            <h3 class="section-title">Quản lý Khách hàng</h3>
            <p class="section-subtitle">Theo dõi thông tin và lịch sử tương tác của khách hàng trên hệ thống.</p>
        </div>
        <div class="booth-search-wrapper">
            <div class="booth-search-box">
                <i class="fa-solid fa-magnifying-glass booth-search-icon"></i>
                <input type="text" id="customers-admin-search" class="booth-search-input"
                       placeholder="Tìm kiếm tên, SĐT hoặc email khách hàng..." autocomplete="off">
                <button type="button" id="customers-admin-search-clear" class="booth-search-clear hidden">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px;">
        
        <div class="glass-card" style="padding:24px; overflow-x:auto; align-self: start;">
            <div class="flex-between mb-4">
                <h3 style="font-size:16px; font-weight:700;">
                    <i class="fa-solid fa-users text-accent" style="margin-right:8px;"></i>Danh sách khách hàng
                </h3>
                <span id="customers-admin-count" style="font-size:12px; color:var(--text-muted);">0 khách hàng</span>
            </div>
            
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Mã KH</th>
                        <th>Họ Tên</th>
                        <th>SĐT</th>
                        <th>Email</th>
                        <th>Ngày đăng ký</th>
                    </tr>
                </thead>
                <tbody id="customers-admin-body">
                </tbody>
            </table>
        </div>

        <div class="glass-card" style="padding:24px; align-self: start;">
            <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">
                <i class="fa-solid fa-user-circle text-accent" style="margin-right:8px;"></i>Chi tiết khách hàng
            </h3>
            
            <div id="customers-admin-details">
                <p style="text-align:center; color:var(--text-dim); padding:40px 0; font-style:italic;">
                    Vui lòng chọn một khách hàng bên danh sách để xem chi tiết.
                </p>
            </div>
        </div>
    </div>
</div>